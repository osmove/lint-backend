<p id="notice"><%= notice %></p>

<h1>Policy Rules</h1>

<table class="table">
  <thead>
    <tr>
      <th>Rule</th>
      <th>Policy</th>
      <th>Position</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @policy_rules.each do |policy_rule| %>
      <tr>
        <td><%= policy_rule.rule %></td>
        <td><%= policy_rule.policy %></td>
        <td><%= policy_rule.position %></td>
        <td><%= link_to 'Show', policy_rule %></td>
        <td><%= link_to 'Edit', edit_policy_rule_path(policy_rule) %></td>
        <td><%= link_to 'Destroy', policy_rule, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Policy Rule', new_policy_rule_path %>
