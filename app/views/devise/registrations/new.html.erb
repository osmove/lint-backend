
<style media="screen">

  html, body {
    height: 100%;
  }

  body {
    /* display: -ms-flexbox;
    display: flex;
    -ms-flex-align: center; */
    align-items: center;
  }

  .form-signin {
    width: 100%;
    max-width: 330px;
    padding: 15px;
    margin: auto;
    padding-top: 50px;
    /* background-color: #f5f5f5; */
  }
  .form-signin .checkbox {
    font-weight: 400;
  }
  .form-signin .form-control {
    position: relative;
    box-sizing: border-box;
    height: auto;
    padding: 10px;
    font-size: 16px;
  }
  .form-signin .form-control:focus {
    z-index: 2;
  }
  .form-signin input[type="text"], .form-signin input[type="email"] {
    margin-bottom: -1px;
    border-bottom-right-radius: 0;
    border-bottom-left-radius: 0;
  }
  .form-signin input[type="password"] {
    margin-bottom: 10px;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
  .email-input {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
</style>


<div class="form-signin text-center">

  <a href="<%= root_path %>">
    <!-- <img class="my-3" src="/images/omnilint-logo.png" alt="" style="max-width: 80px; max-height: 80px; opacity: 0.7;"> -->
    <!-- <img class="mb-3" src="/images/logo/omnilint-logo.svg" style="max-width: 80px; max-height: 80px; opacity: 0.7;" alt="Lint.dev Logo"> -->
    <img class="mb-3" src="/images/logo/omnilint-logo.svg" style="max-width: 100px; max-height: 100px;" alt="Lint.dev Logo">

  </a>

  <h3 class="mb-4">Sign up for Lint.dev.</h3>


  <p>
    <a href="<%= user_github_omniauth_authorize_path %>" class="btn btn-lg btn-primary btn-block mb-3">
      <i class="fa fa-github mr-2" style="font-size: 32px; vertical-align: middle;"></i> <span style="vertical-align: middle;">Sign up with Github</span>
    </a>
  </p>

  <p class="mb-3">or</p>

  <%= bootstrap_form_for(resource, as: resource_name, url:  registration_path(resource_name)) do |f| %>
    <div class="field">
      <%= f.text_field :username, autofocus: true, autocomplete: "username", autocorrect: "off", autocapitalize: "none", hide_label: true, class: "custom-form", placeholder: "Username", wrapper: { class: 'mb-0' } %>
    </div>

    <div class="field">
      <%= f.email_field :email, autocomplete: "email", autocorrect: "off", autocapitalize: "none", hide_label: true, class: "custom-form email-input", placeholder: "Email", wrapper: { class: 'mb-0' } %>
    </div>

    <div class="field">
      <%= f.password_field :password, autocomplete: "off", autocorrect: "off", autocapitalize: "none", hide_label: true, class: "custom-form", placeholder: "Password", wrapper: { class: 'mb-0' }  %>
    </div>


    <% if devise_mapping.rememberable? -%>
      <div class="field mb-3">
        <%= f.check_box :remember_me, class: "custom-form", checked: true %>
      </div>
    <% end %>


    <div class="actions mb-3">
      <%= f.submit "Sign up", class: "btn btn-lg btn-dark btn-block" %>
    </div>

    <p class="mb-2 text-muted">
      Already have an account ?
    </p>

    <p class="text-muted" style="line-height: 1em; font-size: 12px;">
      <%= link_to("Sign in", new_user_session_path, class:'btn btn-outline-secondary btn-lg btn-block') %>
    </p>

    <p class="mt-2 mb-3 text-muted" style="line-height: 1em; font-size: 11px;">
      By clicking "Sign up", you agree to our terms of service and privacy statement. We may occasionally send you account related emails.
    </p>

    <p class="mb-0 text-muted" style="line-height: 1em; font-size: 12px;">
      © 2018 Lint.dev
    </p>

  <% end %>

</div>
