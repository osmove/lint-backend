
<style media="screen">

  html, body {
    height: 100%;
  }

  body {
    /* display: -ms-flexbox;
    display: flex;
    -ms-flex-align: center; */
    align-items: center;
  }

  .form-signin {
    width: 100%;
    max-width: 330px;
    padding: 15px;
    margin: auto;
    padding-top: 50px;
    /* background-color: #f5f5f5; */
  }
  .form-signin .checkbox {
    font-weight: 400;
  }
  .form-signin .form-control {
    position: relative;
    box-sizing: border-box;
    height: auto;
    padding: 10px;
    font-size: 16px;
  }
  .form-signin .form-control:focus {
    z-index: 2;
  }
  .form-signin input[type="text"], .form-signin input[type="email"] {
    margin-bottom: -1px;
    border-bottom-right-radius: 0;
    border-bottom-left-radius: 0;
  }
  .form-signin input[type="password"] {
    margin-bottom: 10px;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
</style>


<div class="form-signin text-center">

  <a href="<%= root_path %>">
    <img class="mb-3" src="/images/logo/gatrix-logo.svg" style="max-width: 80px; max-height: 80px; opacity: 0.7;" alt="Gatrix Logo">

  </a>

  <h3 class="mb-4"><%= "Log In" %></h3>

  <p>
    <a href="<%= user_github_omniauth_authorize_path %>" class="btn btn-lg btn-primary btn-block mb-3">
      <i class="fa fa-github mr-2" style="font-size: 32px; vertical-align: middle;"></i> <span style="vertical-align: middle;">Sign in with Github</span>
    </a>
  </p>

  <p class="mb-3">or</p>

  <%= bootstrap_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <%= f.text_field :login, autofocus: false, autocomplete: "email", autocorrect: "off", autocapitalize: "none", hide_label: true, placeholder: "Username or email", wrapper: { class: 'mb-0' }  %>
    <%= f.password_field :password, autocomplete: "off", autocorrect: "off", autocapitalize: "none", hide_label: true, placeholder: "Password" %>

    <% if devise_mapping.rememberable? -%>
      <div class="field mb-3">
        <%= f.check_box :remember_me, label: "Remember me", inline: true, class:"ml-2", checked: true %>
      </div>
    <% end -%>


    <div class="actions mb-3">
      <%= f.submit "Sign in", class:'btn btn-lg btn-dark btn-block' %>
    </div>

    <%= render "devise/shared/links" %>
  <% end %>

</div>
