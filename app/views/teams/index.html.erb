<div class="container py-4">

  <h1>Teams</h1>

  <div class="mb-3">
    <%= link_to '+ Create New Team', new_user_team_path(current_user), class: 'btn btn-success' %>
  </div>

  <div class="card">
    <div class="card-body">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <!-- <th>Avatar url</th> -->
            <!-- <th>Parent</th> -->
            <th>Description</th>
            <th>Owner</th>
            <th>Members</th>
            <th>Created</th>

            <th colspan="3"></th>
          </tr>
        </thead>

        <tbody>
          <% @teams.each do |team| %>
            <tr>
              <td><%= team.name %></td>
              <!-- <td><%= team.avatar_url %></td> -->
              <!-- <td> <% if team.team_id.present? %><%#= Team.find(team.team_id).name %><% end %></td> -->
              <td><%= team.description %></td>
              <td><%= link_to team.user , user_path(team.user) %></td>
              <td><% if team.memberships.present? %><%= team.memberships.count %><% else %>0<% end %></td>
              <td><%= "#{time_ago_in_words(team.created_at)} ago" %></td>
              <td><%= link_to 'Show', user_team_path(team.user, team.id) %></td>
              <td><%= link_to 'Edit', edit_user_team_path(team.user, team.id) %></td>
              <td><%= link_to 'Destroy', team, method: :delete, data: { confirm: 'Are you sure?' } %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <br>


</div>
