<%= form_with(model: encryption, local: true) do |form| %>
  <% if encryption.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(encryption.errors.count, "error") %> prohibited this encryption from being saved:</h2>

      <ul>
      <% encryption.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :status %>
    <%= form.text_field :status, id: :encryption_status %>
  </div>

  <div class="field">
    <%= form.label :cypher_name %>
    <%= form.text_field :cypher_name, id: :encryption_cypher_name %>
  </div>

  <div class="field">
    <%= form.label :document_id %>
    <%= form.text_field :document_id, id: :encryption_document_id %>
  </div>

  <div class="field">
    <%= form.label :repository_id %>
    <%= form.text_field :repository_id, id: :encryption_repository_id %>
  </div>

  <div class="field">
    <%= form.label :user_id %>
    <%= form.text_field :user_id, id: :encryption_user_id %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
