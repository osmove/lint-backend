<p id="notice"><%= notice %></p>

<h1>Changes</h1>

<table>
  <thead>
    <tr>
      <th>Operation</th>
      <th>Document</th>
      <th>Commit</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @changes.each do |change| %>
      <tr>
        <td><%= change.operation %></td>
        <td><%= change.document %></td>
        <td><%= change.commit %></td>
        <td><%= link_to 'Show', change %></td>
        <td><%= link_to 'Edit', edit_change_path(change) %></td>
        <td><%= link_to 'Destroy', change, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Change', new_change_path %>
