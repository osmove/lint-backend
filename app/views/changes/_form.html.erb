<%= form_with(model: change, local: true) do |form| %>
  <% if change.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(change.errors.count, "error") %> prohibited this change from being saved:</h2>

      <ul>
      <% change.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :operation %>
    <%= form.text_field :operation, id: :change_operation %>
  </div>

  <div class="field">
    <%= form.label :document_id %>
    <%= form.text_field :document_id, id: :change_document_id %>
  </div>

  <div class="field">
    <%= form.label :commit_id %>
    <%= form.text_field :commit_id, id: :change_commit_id %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
