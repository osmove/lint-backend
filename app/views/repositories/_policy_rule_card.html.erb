<% cache policy_rule do %>
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center bg-white"  id="heading_<%= policy_rule.id %>">
      <a href="#" class="" data-bs-toggle="collapse" data-bs-target="#collapse_<%= policy_rule.id %>" aria-expanded="<% if (i == 0) %>false<% else %>true<% end %>" aria-controls="collapse_collapse_<%= policy_rule.id %>">
        <%= policy_rule.name %>
        <% if policy_rule.fixable? && policy_rule.linter.command != "prettier"%>
          <i class='fa fa-wrench text-muted'></i>
        <% end %>
        <span class="text-muted"> - <%= policy_rule.short_description %></span>
      </a>
      <% if policy_rule.linter.command != "prettier" %>
        <% if policy_rule.status == "off" %>
          <span class="badge badge badge-secondary">Off</span>
        <% elsif policy_rule.status == "warn" %>
          <span class="badge badge badge-warning">Warning</span>
        <% else policy_rule.status == "error" %>
          <span class="badge badge badge-danger">Error</span>
        <% end %>
      <% elsif policy_rule.linter.command == "prettier" %>
        <% if policy_rule.status == "off" %>
          <span class="badge badge badge-secondary">Off</span>
        <% elsif policy_rule.status == "on" %>
          <span class="badge badge badge-success">On</span>
        <% end %>

      <% end %>

    </div>

    <div id="collapse_<%= policy_rule.id %>" class="collapse" aria-labelledby="heading_<%= policy_rule.id %>" data-bs-parent="#accordion_<%= policy_rule.id %>">
      <div class="card-body bg-light">
        <span class="text-muted"><%= policy_rule.description %></span>
      </div>
      <ul class="list-group list-group-flush">
        <% policy_rule.policy_rule_options.each do |pro| %>
          <% if pro.rule_option.present? %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <span>
                <%= pro.rule_option.name %>
                <p class="text-muted"><%= pro.rule_option.description %></p>
              </span>
              <% if pro.rule_option.value_type != "array-multiple"%>
                <p class="card-text text-muted"><%= pro.value %></p>
              <% else %>
                <p class="card-text text-muted">
                  <% pro.rule_option_options.each do |selected| %>
                    <%= selected.value %>
                  <% end %>
                </p>
              <% end %>
            </li>
          <% end %>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
