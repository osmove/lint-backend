    <script type="text/javascript">
      function selectDeployTo(deployTo) {
        if (deployTo == 'omnilint_cloud') {
          document.getElementById('omnilint_cloud').style.display = "block";
          document.getElementById('aws').style.display = "none";
          document.getElementById('gcp').style.display = "none";
          document.getElementById('azure').style.display = "none";
          document.getElementById('own_server').style.display = "none";
        } else if (deployTo == 'aws') {
          document.getElementById('omnilint_cloud').style.display = "none";
          document.getElementById('aws').style.display = "block";
          document.getElementById('gcp').style.display = "none";
          document.getElementById('azure').style.display = "none";
          document.getElementById('own_server').style.display = "none";
        } else if (deployTo == 'gcp') {
          document.getElementById('omnilint_cloud').style.display = "none";
          document.getElementById('aws').style.display = "none";
          document.getElementById('gcp').style.display = "block";
          document.getElementById('azure').style.display = "none";
          document.getElementById('own_server').style.display = "none";
        } else if (deployTo == 'azure') {
          document.getElementById('omnilint_cloud').style.display = "none";
          document.getElementById('aws').style.display = "none";
          document.getElementById('gcp').style.display = "none";
          document.getElementById('azure').style.display = "block";
          document.getElementById('own_server').style.display = "none";
        } else if (deployTo == 'own_server') {
          document.getElementById('omnilint_cloud').style.display = "none";
          document.getElementById('aws').style.display = "none";
          document.getElementById('gcp').style.display = "none";
          document.getElementById('azure').style.display = "none";
          document.getElementById('own_server').style.display = "block";
        } else {
          document.getElementById('omnilint_cloud').style.display = "none";
          document.getElementById('aws').style.display = "none";
          document.getElementById('gcp').style.display = "none";
          document.getElementById('azure').style.display = "none";
          document.getElementById('own_server').style.display = "none";
        }
        return false;
      }





