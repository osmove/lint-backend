  <%= form.hidden_field :platform_id %>

  <div class="card my-3">
    <div class="card-body text-center">
      <p id="platform_error">Select your development platform:</p>


      <nav class="text-center" style="text-align: center !important;">
        <div class="nav nav-tabs text-center mx-auto" role="tablist" style="max-width: 250px;">
          <a class="nav-item nav-link active" id="nav_popular" href="#popular" data-toggle="tab" role="tab" aria-selected="true" style="width: 120px; cursor: pointer; border: 1px solid #ccc; border-bottom: none;">Popular</a>
          <a class="nav-item nav-link" id="nav_all" href="#all" data-toggle="tab" role="tab" aria-selected="false" style="width: 120px; cursor: pointer; border: 1px solid #ccc; border-bottom: none;">All</a>
        </div>
      </nav>



      <section class="tab-content" style="border-top: 1px solid #ccc; padding-top: 20px;">
        <div class="tab-pane fade show active" id="popular" role="tabpanel" aria-labelledby="popular-tab">
          <div class="row">
            <% Platform.where(is_popular: true).order(slug: :asc).each do |platform| %>
              <div class="col-4 col-md-3 col-lg-2 mb-2">
                <a href="#" style="color: #000;" onclick="selectPlatform('<%= platform.id %>'); return false;">
                  <div class="platform-box" id="platform_<%= platform.id %>_popular">
                    <img src="<%= platform.image_url %>" class="img-fluid mb-1" alt="">
                    <%= platform.name %>
                  </div>
                </a>
              </div>
            <% end %>
          </div>
        </div>
        <div class="tab-pane fade" id="all" role="tabpanel" aria-labelledby="all-tab">
          <div class="row">
            <% Platform.all.order(slug: :asc).each do |platform| %>
              <div class="col-4 col-md-3 col-lg-2 mb-2">
                <a href="#" style="color: #000;" onclick="selectPlatform('<%= platform.id %>'); return false;">
                  <div class="platform-box" id="platform_<%= platform.id %>">
                    <img src="<%= platform.image_url %>" class="img-fluid mb-1" alt="">
                    <%= platform.name %>
                  </div>
                </a>
              </div>
            <% end %>
          </div>
        </div>
      </section>

    </div>
  </div>

  <script type="text/javascript">
    function selectPlatform(id) {
      const oldId = document.getElementById('repository_platform_id').value;
      document.getElementById('repository_platform_id').value = id;
      if (oldId) {
        document.getElementById('platform_' + oldId).style.borderColor = "#fff";
        document.getElementById('platform_' + oldId).style.backgroundColor = "#fff";
        document.getElementById('platform_' + oldId + '_popular').style.borderColor = "#fff";
        document.getElementById('platform_' + oldId + '_popular').style.backgroundColor = "#fff";
      }
      document.getElementById('platform_' + id).style.borderColor = "#006ee0";
      document.getElementById('platform_' + id).style.backgroundColor = "#c7e1fc";
      document.getElementById('platform_' + id + '_popular').style.borderColor = "#006ee0";
      document.getElementById('platform_' + id + '_popular').style.backgroundColor = "#c7e1fc";
      return false;
    }
    // Init
    const nameSent = document.getElementById('repository_name');
    const platformSent = document.getElementById('repository_platform_id');
    if (platformSent.value) {
      document.getElementById('platform_' + platformSent.value).style.borderColor = "#006ee0";
      document.getElementById('platform_' + platformSent.value).style.backgroundColor = "#c7e1fc";
      document.getElementById('platform_' + platformSent.value + '_popular').style.borderColor = "#006ee0";
      document.getElementById('platform_' + platformSent.value + '_popular').style.backgroundColor = "#c7e1fc";
    }

    // if (nameSent) {
    //   if (platformSent) {
    //     document.getElementById('platform_' + platformSent).style.borderColor = "#006ee0";
    //     document.getElementById('platform_' + platformSent).style.backgroundColor = "#c7e1fc";
    //   } else {
    //     document.getElementById('platform_error').style.color = "#b00";
    //   }
    // }

    // if (nameSent && !platformSent) {
    //   document.getElementById('platform_error').style.color = "#b00";
    // }

    function convertToSlug(Text)
    {
      return Text
        .toLowerCase()
        .replace(/[^\w ]+/g,'')
        .replace(/ +/g,'-')
        ;
    }

    function convertSelfToSlug(Text)
    {
      return Text
        .toLowerCase()
        .replace(/ /g,'-')
        .replace(/[^\w-]+/g,'')
        ;
    }

  </script>


  <script type="text/javascript">
    function updateDomainSlug(name) {
      document.getElementById('domain_slug').value = "<%= current_user.slug %>-" + convertToSlug(name);
    }
    function updateSelfDomainSlug(name) {
      document.getElementById('domain_slug').value = convertSelfToSlug(name);
    }




  </script>



  <div class="mb-3">
    <div class="pt-3">
      <% if @repository.id.present? %>
        <%= form.text_field :name, id: :repository_name, label: { text: "Name" }, help: "The name of your repository.", prepend: "#{@repository.user.slug}/", input_group_class: "input-group-lg mb-0", id: "name_field", onkeyup: "updateDomainSlug(this.value);", placeholder: "My Great Repo", autofocus: true, disabled: true %>
      <% else %>
        <%= form.text_field :name, id: :repository_name, label: { text: "Name" }, help: "The name of your repository.", prepend: "#{current_user.slug}/", input_group_class: "input-group-lg mb-0", id: "name_field", onkeyup: "updateDomainSlug(this.value);", placeholder: "my-great-repo", autofocus: true %>
      <% end %>
    </div>
  </div>



  <div class="mb-3">
    <div class="row">
      <div class="col-3">
        Slug
      </div>
      <div class="col-9">
        <div id="permalink_show">
          <div>
            <%= request.base_url + user_path %>/<span id="permalink" style="font-weight:bold; background-color: #FFFFD6;"><%= @repository.slug || "my-great-repo" %></span>
          </div>
          <a href="#" id="permalink_edit">Edit</a>
        </div>

        <div id="edit_permalink_row" style="display: none;">
          <%= form.text_field :slug, id: :repository_slug, placeholder: "my-great-repo", hide_label: true %>
          <div class="help-block">The slug can't be changed later. <a href="#" id="permalink_ok" class="">OK</a></div>
        </div>

      </div>
    </div>
  </div>




  <script type="text/javascript">
    $( "#permalink_edit" ).click(function() {
      $("#edit_permalink_row").show();
      $("#permalink_show").hide();
      $("#repository_slug").focus();
    });

    $( "#permalink_ok" ).click(function() {
      $("#edit_permalink_row").hide();
      $("#permalink_show").show();
      $("#name_field").focus();
    });



    $("#name_field").keyup(function() {
      var value = $(this).val()
            .toLowerCase()
            .replace(/[^\w ]+/g,'')
            .replace(/ +/g,'-')
            ;

        $("#permalink").html( value );
        $("#repository_slug").val( value );

      // $("#product_name_he").val( value );

      // $(this).val($(this).val().replace(/^\s/g,'').replace(/\s{2}/g,''));
    })


    $("#repository_slug").keyup(function() {
      var value = $(this).val()
            .toLowerCase()
            .replace(/ /g,'-')
            .replace(/[^\w-]+/g,'')
            .replace(/-+/g,'-')
            ;
      $(this).val(value);
      $("#permalink").html( value );
    })

    $("#repository_slug").blur(function() {
      var value = $(this).val().replace(/-$/,'');
      $(this).val(value);
      $("#permalink").html( value );
    })
  </script>

