
<style media="screen">
  .search-dark {
    background-color: #000;
  }
  .search-dark:focus {
    background-color: #fff !important;
  }
</style>
<form class="form-inline form-search input-search mr-0 mr-md-2" id="search" action="/repositories" autocomplete="off">
  <div class="input-group" id="scrollable-dropdown-menu">
    <% if !params["q"].blank? %>
      <input class="form-control typeahead input-search search-dark typeahead-navbar border-0" style="border-radius: 5px 0px 0px 5px;" type="search" placeholder="<%= params['q'] %>" aria-label="Search" name="q" value="<%= @query %>" autocomplete="off" id="search_input">
    <% else %>
      <input class="form-control typeahead input-search search-dark typeahead-navbar border-0" style="border-radius: 5px 0px 0px 5px;" type="search" placeholder="Search" aria-label="Search" name="q" value="<%= @query %>" autocomplete="off" id="search_input">
    <% end %>
    <div class="input-group-append">
      <button class="btn btn-dark text-muted px-md-3 px-lg-4 btn-magnifier" type="submit" ><i class="fa fa-search"></i></button>
    </div>
  </div>
</form>





<script type="text/javascript">
  // Twitter typeahead example.

  var users = new Bloodhound({
    datumTokenizer: Bloodhound.tokenizers.obj.whitespace('slug'),
    queryTokenizer: Bloodhound.tokenizers.whitespace,
    prefetch: '/users.json',
    remote: {
      url: '/users.json?q=%QUERY',
      wildcard: '%QUERY'
    }
  });
  users.initialize(); // initialize the bloodhound suggestion engine


  // instantiate the typeahead UI
  $('.typeahead').typeahead({
    highlight: true,
    minLength: 0,
  }, {
    display: 'slug',
    // source: repositories,
    source: users.ttAdapter(),
    limit: 3,
    templates: {
      header: '<h6 class="px-3 text-muted bg-light py-2 mt-1 mb-1" style="border-bottom: 1px solid #ddd; border-top: 1px solid #cfd4d9; font-size: 12px;"><i class="fa fa-users mr-1"></i> USERS</h6>',
      empty: [
        '<h6 class="px-3 text-muted bg-light py-2 mt-1 mb-1" style="border-bottom: 1px solid #ddd; border-top: 1px solid #cfd4d9; font-size: 12px;"><i class="fa fa-users mr-1"></i> USERS</h6>',
        '<div class="text-md-center py-2 text-muted">',
          '<p class="px-3 mb-0">No result</p>',
        '</div>'
      ].join('\n'),
      // suggestion: Handlebars.compile('<div><strong>{{uuid}}</strong> – {{slug}}</div>')
    }
  }).on('typeahead:selected', function(val) {
    // $("form#search").submit()
    window.location = `/${$('#search_input').val()}`
  });
</script>
