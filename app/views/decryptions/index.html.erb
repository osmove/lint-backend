<p id="notice"><%= notice %></p>

<h1>Decryptions</h1>

<table>
  <thead>
    <tr>
      <th>Status</th>
      <th>Cypher name</th>
      <th>Document</th>
      <th>Repository</th>
      <th>User</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @decryptions.each do |decryption| %>
      <tr>
        <td><%= decryption.status %></td>
        <td><%= decryption.cypher_name %></td>
        <td><%= decryption.document %></td>
        <td><%= decryption.repository %></td>
        <td><%= decryption.user %></td>
        <td><%= link_to 'Show', decryption %></td>
        <td><%= link_to 'Edit', edit_decryption_path(decryption) %></td>
        <td><%= link_to 'Destroy', decryption, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Decryption', new_decryption_path %>
