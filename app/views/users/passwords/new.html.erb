<div class="container py-5 text-center" style="max-width: 600px;">

  <h2>Forgot your password?</h2>

  <%= bootstrap_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%#= devise_error_messages! %>

    <div class="field">
      <%= f.text_field :username, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="actions">
      <%= f.submit "Send me reset password instructions", class: "btn btn-primary mb-3"  %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
