<div style="background-color: #f8f9fa; color: #555; text-align: center; padding: 20px 10px 30px 10px; margin: 0; font-size: 15px; font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;">
  <a href="https://www.omnilint.com/">
    <img src="https://www.omnilint.com/images/mailer/logo.png" alt="Omnilint Logo" width="140" height="30" style="margin-bottom: 15px;" />
  </a>
  <div style="background-color: #ffffff; text-align: center; max-width: 650px; margin-left: auto; margin-right: auto; margin-bottom: 30px; padding: 30px 20px 30px 20px; border-top: 3px solid #333333;">
    <p>Welcome <%= @resource.username %>,</p>
    <p>Thank you for creating your Omnilint account.</p>
    <p>Please verify your account email through the link below:</p>
    <p>
      <a href="<%= confirmation_url(@resource, confirmation_token: @token) %>" style="border-radius:4px;color:#fff;padding:7px 8px;text-decoration:none;border:1px solid #0069d9;display:inline-block;font-weight:400;line-height:18px;background-color:#0069d9">
        Confirm my account
      </a>
    </p>
  </div>
</div>
