<% content_for :title do %>Create account — Lint<% end %>

<section class="relative isolate py-16 md:py-24 overflow-hidden">
  <div aria-hidden="true"
       class="pointer-events-none absolute -top-32 -right-32 -z-10 h-[560px] w-[560px] rounded-full"
       style="background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, rgba(34,211,238,0) 70%);"></div>

  <div class="max-w-md mx-auto px-4">
    <div class="text-center mb-8">
      <span class="inline-flex w-14 h-14 rounded-2xl bg-[#0b1120] ring-1 ring-white/10 items-center justify-center mb-4">
        <svg viewBox="0 0 100 100" class="w-9 h-9" aria-hidden="true">
          <g fill="none" stroke="#22d3ee" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="36,32 22,50 36,68"/>
            <line x1="56" y1="32" x2="44" y2="68"/>
            <polyline points="64,32 78,50 64,68"/>
          </g>
        </svg>
      </span>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white">Create your account.</h1>
      <p class="mt-2 text-slate-400">Start gating bad code in under a minute.</p>
    </div>

    <% if defined?(user_osmove_omniauth_authorize_path) %>
      <%= button_to user_osmove_omniauth_authorize_path, method: :post, data: { turbo: false }, form: { class: "w-full" }, class: "w-full inline-flex items-center justify-center gap-2 rounded-lg bg-cyan-300 text-slate-950 hover:bg-cyan-200 px-5 py-3 font-semibold transition-colors mb-3" do %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-950 text-[10px] font-bold text-cyan-300">O</span>
        Sign up with Osmove
      <% end %>
    <% end %>

    <% if defined?(user_github_omniauth_authorize_path) %>
      <%= button_to user_github_omniauth_authorize_path, method: :post, data: { turbo: false }, form: { class: "w-full" }, class: "w-full inline-flex items-center justify-center gap-2 rounded-lg bg-white text-slate-950 hover:bg-white/90 px-5 py-3 font-semibold transition-colors" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        Sign up with GitHub
      <% end %>

      <div class="my-6 flex items-center gap-3">
        <div class="flex-1 h-px bg-white/10"></div>
        <span class="text-xs uppercase tracking-wider text-slate-500">or with email</span>
        <div class="flex-1 h-px bg-white/10"></div>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <% input_classes = "w-full rounded-lg bg-white/[0.04] border border-white/10 focus:border-brand-400 focus:ring-2 focus:ring-brand-500/30 focus:outline-none px-4 py-3 text-white placeholder:text-slate-500 transition-colors" %>

      <% if resource.errors.any? %>
        <div class="rounded-xl bg-rose-500/10 border border-rose-500/30 p-4 text-sm text-rose-200">
          <ul class="list-disc pl-5 space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if resource.respond_to?(:username) %>
        <div>
          <label for="user_username" class="block text-xs uppercase tracking-wide text-slate-400 mb-2">Username</label>
          <%= f.text_field :username, id: :user_username, autofocus: true, autocomplete: "username", autocorrect: "off", autocapitalize: "none", placeholder: "yourname", class: input_classes %>
        </div>
      <% end %>

      <div>
        <label for="user_email" class="block text-xs uppercase tracking-wide text-slate-400 mb-2">Email</label>
        <%= f.email_field :email, id: :user_email, autocomplete: "email", autocorrect: "off", autocapitalize: "none", placeholder: "you@company.com", class: input_classes %>
      </div>

      <div>
        <label for="user_password" class="block text-xs uppercase tracking-wide text-slate-400 mb-2">Password</label>
        <%= f.password_field :password, id: :user_password, autocomplete: "new-password", placeholder: "•••••••••", class: input_classes %>
        <% if @minimum_password_length %>
          <p class="mt-1 text-xs text-slate-500">Minimum <%= @minimum_password_length %> characters.</p>
        <% end %>
      </div>

      <% if resource.respond_to?(:password_confirmation) %>
        <div>
          <label for="user_password_confirmation" class="block text-xs uppercase tracking-wide text-slate-400 mb-2">Confirm password</label>
          <%= f.password_field :password_confirmation, id: :user_password_confirmation, autocomplete: "new-password", placeholder: "•••••••••", class: input_classes %>
        </div>
      <% end %>

      <%= f.submit "Create account", class: "w-full inline-flex items-center justify-center gap-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-white px-5 py-3 font-semibold shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30 cursor-pointer transition-all" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-slate-400">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-brand-300 hover:text-brand-200 underline" %>
    </p>

    <p class="mt-4 text-center text-xs text-slate-500">
      By signing up you agree to our
      <a href="/terms" class="text-slate-400 hover:text-slate-300 underline">Terms</a> and
      <a href="/privacy" class="text-slate-400 hover:text-slate-300 underline">Privacy Policy</a>.
    </p>
  </div>
</section>
