<section class="bg-light">
  <div class="container py-4">


    <% if current_user == @user %>
      <h3>Last Commit Attempts</h3>
      <div class="mb-3">
        <%= column_chart [
          {name: 'Passed', color: 'green', data: @user.policy_checks.where(passed: true).group_by_day(:created_at, last: 30).count},
          {name: 'Failed', color: 'red', data: @user.policy_checks.where(passed: false).group_by_day(:created_at, last: 30).count}
        ], height: "300px", stacked: true
        %>
      </div>
    <% end %>



    <div class="row">
      <div class="col-12 col-md-7 col-lg-8">

        <% if @repositories.length > 0 %>
          <% if @repositories.length == 1 %>
            <p class="my-2 text-muted"><small>1 PUBLIC REPOSITORY</small></p>
          <% else %>
            <p class="my-2 text-muted"><small><%= @repositories.length %> PUBLIC REPOSITORIES</small></p>
          <% end %>
          <%= render "user_repositories", repositories: @repositories %>
        <% else %>
          <%= render "repositories/tabs/empty" %>
        <% end %>

      </div>


      <div class="col-12 col-md-5 col-lg-4" style="font-size: 14px; color: #333;">

