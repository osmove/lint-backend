            <% if repository.platform.present? %>
              <img class="mr-2 mr-md-3" src="<%= repository.platform.image_url %>" alt="" style="width: 50px; height: 50px; float: left; border-radius: 8px;" />
            <% else %>
              <img class="mr-2 mr-md-3" src="/images/platformicons/svg/generic.svg" alt="" style="width: 50px; height: 50px; float: left; border-radius: 8px;" />
            <% end %>

            <h6 class="" style="margin-top: 6px; margin-bottom: 3px; ">
              <%= repository.user.slug.downcase %> <span class="text-muted">/</span> <strong><%= repository.slug %></strong>

              <% if repository.git_host == 'github' %>
                <i class="fa fa-github text-muted"></i>
              <% end %>
              <% if repository.status == 'Private' %>
                <i class="fa fa-eye-slash text-muted"></i>
              <% end %>
              <% if repository.has_encryption %>
                <i class="fa fa-lock text-muted"></i>
              <% end %>
              <small>
                <% if repository.requires_two_step_authentication %>
                  <i class="fa fa-shield text-muted"></i>
                <% end %>
                <% if repository.has_deployment %>
                  <i class="fa fa-desktop text-muted"></i>
                <% end %>
              </small>
            </h6>



            <ul class="list-unstyled text-dark mb-0" style="font-size: 12px;">
              <% if repository.user == current_user %>

                <!-- <% if repository.status == 'Private' %>
                  <li>Visibility: <i class="fa fa-eye-slash text-muted"></i> <strong><%= repository.status %></strong> </li>
                <% else %>
                  <li>Visibility: <strong><%= repository.status %></strong> </li>
                <% end %>

                <% if repository.has_encryption %>
                  <li>End-to-end encryption: <i class="fa fa-lock text-muted"></i> <strong>Yes</strong></li>
                <% else %>
                  <li>End-to-end encryption: <strong>No</strong> </li>
                <% end %>

                <% if repository.requires_two_step_authentication %>
                  <li>Two-step authentication: <i class="fa fa-shield text-muted"></i> <strong>Yes</strong></li>
                <% else %>
                  <li>Two-step authentication: <strong>No</strong> </li>
                <% end %>

                <% if repository.has_deployment %>
                  <li>Deployment: <i class="fa fa-desktop text-muted"></i> <strong>Yes</strong></li>
                <% else %>
                  <li>Deployment: <strong>No</strong></li>
                <% end %> -->
              <% end %>


