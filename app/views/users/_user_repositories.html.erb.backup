
<div class="row">
  <% repositories.each do |repo| %>
    <!-- <div class="col-12 col-sm-6 col-lg-6"> -->
    <div class="col-12">
      <a href="<%= user_repository_path(repo.user, repo) %>" style="display: block; cursor: pointer;">
        <div class="card box-shadow mb-3" style="min-height: 110px;">
          <div class="card-header">
            <!-- <h4 class="my-0 font-weight-normal">Free</h4> -->
            <h5 class="card-title my-0">
              <%= repo.user.slug.downcase %> <span class="text-muted">/</span> <strong><%= repo.slug %></strong>

                <% if repo.status == 'Private' %>
                  <i class="fa fa-eye-slash text-muted"></i>
                <% end %>
                <% if repo.has_encryption %>
                  <i class="fa fa-lock text-muted"></i>
                <% end %>
              <small>
                <% if repo.requires_two_step_authentication %>
                  <i class="fa fa-shield text-muted"></i>
                <% end %>
                <% if repo.has_deployment %>
                  <i class="fa fa-desktop text-muted"></i>
                <% end %>
              </small>
            </h5>
          </div>
          <div class="card-body">
            <!-- <p class="card-subtitle mb-2 text-muted"><%= repo.slug %></p> -->
            <ul class="list-unstyled text-dark mb-0" style="font-size: 13px;">
              <% if repo.user == current_user %>

                <!-- <% if repo.status == 'Private' %>
                  <li>Visibility: <i class="fa fa-eye-slash text-muted"></i> <strong><%= repo.status %></strong> </li>
                <% else %>
                  <li>Visibility: <strong><%= repo.status %></strong> </li>
                <% end %>

                <% if repo.has_encryption %>
                  <li>End-to-end encryption: <i class="fa fa-lock text-muted"></i> <strong>Yes</strong></li>
                <% else %>
                  <li>End-to-end encryption: <strong>No</strong> </li>
                <% end %>

                <% if repo.requires_two_step_authentication %>
                  <li>Two-step authentication: <i class="fa fa-shield text-muted"></i> <strong>Yes</strong></li>
                <% else %>
                  <li>Two-step authentication: <strong>No</strong> </li>
                <% end %>

                <% if repo.has_deployment %>
                  <li>Deployment: <i class="fa fa-desktop text-muted"></i> <strong>Yes</strong></li>
                <% else %>
                  <li>Deployment: <strong>No</strong></li>
                <% end %> -->
              <% end %>

              <li>Created: <strong><%= time_ago_in_words(repo.created_at) %> ago</strong></li>
              <li>Updated: <strong><%= time_ago_in_words(repo.updated_at) %> ago</strong></li>

              <!-- <% if repo.created_at == repo.updated_at %>
                <li>Created: <strong><%= time_ago_in_words(repo.created_at) %> ago</strong></li>
              <% else %>
                <li>Updated: <strong><%= time_ago_in_words(repo.updated_at) %> ago</strong></li>
              <% end %> -->

            </ul>
            <!-- <p class="card-subtitle text-muted mb-2"><strong>Created: </strong><%= time_ago_in_words(repo.created_at) %> ago</p> -->
            <!-- <p class="card-subtitle text-muted"><strong>Updated: </strong><%= time_ago_in_words(repo.updated_at) %> ago</p> -->
          </div>
        </div>
      </a>
    </div>
  <% end %>
</div>
