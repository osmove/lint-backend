<section class="bg-white">
  <div class="container py-4 py-md-5">

    <div class="row">
      <div class="col-12 col-sm-6">
        <h2>Platforms <span class="badge badge-secondary"><%= @platforms.length %></span></h2>
      </div>
      <div class="col-12 col-sm-6">
        <p class="text-sm-right">
          <a href="<%= new_platform_path %>" class="btn btn-success">
            + New Platform
          </a>
        </p>
      </div>
    </div>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th width="30">Image</th>
            <th>Name</th>
            <th>Slug</th>
            <th>Language</th>
            <th>Framework</th>
            <th>Popular</th>
            <th colspan="3"></th>
          </tr>
        </thead>

        <tbody>
          <% @platforms.each do |platform| %>
            <tr>
              <td><img src="<%= raw platform.image_url %>" alt="<%= platform.name %>"></td>
              <!-- <td><img src="" alt=""><%= raw platform.image %></td> -->
              <td><%= platform.name %></td>
              <td><%= platform.slug %></td>
              <td><%= platform.language %></td>
              <td><%= platform.framework %></td>
              <td><%= platform.is_popular %></td>
              <td><%= link_to 'Show', platform %></td>
              <td><%= link_to 'Edit', edit_platform_path(platform) %></td>
              <td><%= link_to 'Destroy', platform, method: :delete, data: { confirm: 'Are you sure?' } %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= link_to 'New Platform', new_platform_path %>

  </div>
</section>
