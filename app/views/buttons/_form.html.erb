<%= form_with(model: button, local: true) do |form| %>
  <% if button.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(button.errors.count, "error") %> prohibited this button from being saved:</h2>

      <ul>
      <% button.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :command_id %>
    <%= form.text_field :command_id, id: :button_command_id %>
  </div>

  <div class="field">
    <%= form.label :repository_id %>
    <%= form.text_field :repository_id, id: :button_repository_id %>
  </div>

  <div class="field">
    <%= form.label :user_id %>
    <%= form.text_field :user_id, id: :button_user_id %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
