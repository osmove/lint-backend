<section class="bg-white">
  <div class="bg-white">
    <div class="tab-content" id="nav-tabContent">
      <div class="tab-pane fade show active" id="nav-overview" role="tabpanel" aria-labelledby="nav-overview-tab">
        <%= render 'repositories/tabs/overview', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-files" role="tabpanel" aria-labelledby="nav-files-tab">
        <%= render 'repositories/tabs/files', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-commits" role="tabpanel" aria-labelledby="nav-commits-tab">
        <%= render 'repositories/tabs/commits', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-issues" role="tabpanel" aria-labelledby="nav-issues-tab">
        <%= render 'repositories/tabs/issues', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-pull-request" role="tabpanel" aria-labelledby="nav-pull-request-tab">
        <%= render 'repositories/tabs/pull_requests', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-analytics" role="tabpanel" aria-labelledby="nav-analytics-tab">
        <%= render 'repositories/tabs/analytics', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-ratings" role="tabpanel" aria-labelledby="nav-ratings-tab">
        <%= render 'repositories/tabs/ratings', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-access" role="tabpanel" aria-labelledby="nav-access-tab">
        <%= render 'repositories/tabs/access', repository: @repository %>
      </div>
      <div class="tab-pane fade" id="nav-settings" role="tabpanel" aria-labelledby="nav-settings-tab">
        <%= render 'repositories/tabs/settings', repository: @repository %>
      </div>
    </div>
  </div>
</section>

