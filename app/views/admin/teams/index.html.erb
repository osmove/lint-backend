<p id="notice"><%= notice %></p>

<h1>Teams</h1>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Avatar url</th>
      <th>Parent</th>
      <th>Description</th>
      <th>Organization</th>
      <th>Members</th>

      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @teams.each do |team| %>
      <tr>
        <td><%= team.name %></td>
        <td><%= team.avatar_url %></td>
        <td> <% if team.team_id.present? %><%= Team.find(team.team_id).name %><% end %></td>
        <td><%= team.description %></td>
        <td><%= team.user %></td>
        <td><% if team.memberships.present? %><%= team.memberships.count %><% end %></td>

        <td><%= link_to 'Show', admin_team_path(team.id) %></td>
        <td><%= link_to 'Edit', edit_admin_team_path(team.id) %></td>
        <td><%= link_to 'Destroy', team, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Team', new_admin_team_path %>
