<%= lint_form_for(@push, :url => @form_url)do |form| %>
  <% if push.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(push.errors.count, "error") %> prohibited this push from being saved:</h2>

      <ul>
      <% push.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :repository_id %>
    <%= form.collection_select :repository_id, Repository.all, :id, :name, hide_label: true %>
  </div>

  <div class="field">
    <%= form.label :user_id %>
    <%= form.collection_select :user_id, User.all, :id, :username, hide_label: true %>
  </div>

  <div class="field">
    <%= form.label :commit_ids %>
    <%= form.collection_select :commit_ids, Commit.all, :id, :message,{ :prompt => "Please select"}, { :multiple => true, :size => 5, hide_label: true } %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
