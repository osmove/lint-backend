<%= lint_form_for(@decryption, url: @form_url) do |form| %>
  <% if @decryption.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@decryption.errors.count, "error") %> prohibited this decryption from being saved:</h2>

      <ul>
      <% @decryption.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :status %>
    <%= form.text_field :status, id: :decryption_status %>
  </div>

  <div class="field">
    <%= form.label :cypher_name %>
    <%= form.text_field :cypher_name, id: :decryption_cypher_name %>
  </div>
  <div class="field">
  <%= form.label :document_id %>
  <%= form.collection_select :document_id, Document.all, :id, :name, hide_label: true %>
  </div>

  <div class="field">
    <%= form.label :repository_id %>
    <%= form.collection_select :repository_id, Repository.all, :id, :name, hide_label: true %>
  </div>

  <div class="field">
    <%= form.label :user_id %>
    <%= form.collection_select :user_id, User.all, :id, :username, hide_label: true %>
  </div>
  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
