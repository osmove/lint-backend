<div class="container-fluid py-2">
  <div class="row justify-content-between">
    <h1>Decryptions</h1>
    <%= paginate @decryptions %>
  </div>

  <div class="row">
    <%= link_to "+ New Decryption", new_admin_decryption_path, class: "btn btn-primary my-3" %>
  </div>

</div>


<table class="table">
  <thead>
    <tr>
      <th>Status</th>
      <th>Cypher name</th>
      <th>Document</th>
      <th>Repository</th>
      <th>User</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @decryptions.each do |decryption| %>
      <tr>
        <td><%= decryption.status %></td>
        <td><%= decryption.cypher_name %></td>
        <td><%= decryption.document %></td>
        <td><%= decryption.repository %></td>
        <td><%= decryption.user %></td>
        <td><%= link_to 'Show', admin_decryption_url(decryption) %></td>
        <td><%= link_to 'Edit', edit_admin_decryption_path(decryption) %></td>
        <td><%= link_to 'Destroy', admin_decryption_url(decryption), method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
