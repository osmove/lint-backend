<section class="bg-white">
  <div class="container py-4 py-md-5">

    <div class="row">
      <div class="col-12 col-sm-6">
        <h2>Frameworks <span class="badge badge-secondary"><%= @frameworks.length %></span></h2>
      </div>
      <div class="col-12 col-sm-6">
        <p class="text-sm-right">
          <a href="<%= new_admin_framework_path %>" class="btn btn-success">
            + New Framework
          </a>
        </p>
      </div>
    </div>


    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th width="30">Image</th>
            <th>Name</th>
            <th>Slug</th>
            <th colspan="3"></th>
          </tr>
        </thead>

        <tbody>
          <% @frameworks.each do |framework| %>
            <tr>
              <td><img src="<%= raw framework.image_url %>" alt="<%= framework.name %>"></td>
              <!-- <td><%= raw framework.image %></td> -->
              <td><%= framework.name %></td>
              <td><%= framework.slug %></td>
              <td><%= link_to 'Show', admin_framework_path(framework) %></td>
              <td><%= link_to 'Edit', edit_admin_framework_path(framework) %></td>
              <td><%= link_to 'Destroy', admin_framework_path(framework), method: :delete, data: { confirm: 'Are you sure?' } %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <%= paginate @frameworks %>

    </div>

  </div>
</section>
