<div class="nested-fields">
	<div class="card">
		<div class="card-header d-flex justify-content-between align-items-center bg-white",  id="heading_<%= rule.id %>">
			<a href="#" class="" data-bs-toggle="collapse" data-bs-target="#collapse_<%= rule.id %>" aria-expanded="false" aria-controls="collapse_collapse_<%= rule.id %>">
				<% if rule.fixable && rule.linter.command != "prettier" %>
					<%= f.check_box :rule_id, {label: "<strong>#{rule.name} <i class='fa fa-wrench text-muted'></i></strong>".html_safe, inline: true, class: "mr-3", checked: true, style: "display: none;" }, rule.id, nil %>
				<% else %>
					<%= f.check_box :rule_id, {label: "<strong>#{rule.name}</strong>".html_safe, inline: true, class: "mr-3", checked: true, style: "display: none;" }, rule.id, nil %>
				<% end %>
				<%# if rule.name != rule.slug %>
				<% if rule.description.length > 60 %>
					<span class="text-muted"> - <%= "#{rule.description.slice(0, 60)}..." %></span>
				<% else %>
					<span class="text-muted"> - <%= rule.description %></span>

				<% end %>

				<%# end %>
			</a>

			<% if rule.linter.command != "prettier" %>
				<div class="ml-3" style="min-width: 200px;">
					<%= f.collection_radio_buttons( :status, PolicyRule::STATUS_OPTIONS, :last, :first, {hide_label: true, inline: true, layout: :default } ) %>
				</div>
			<% elsif rule.linter.command == "prettier"%>
				<%= f.collection_radio_buttons( :status, [[ "Off","off"],["On", "on"]], :last, :first, {hide_label: true, inline: true, layout: :default } ) %>
			<% end %>

		</div>
		<div id="collapse_<%= rule.id %>" class="collapse" aria-labelledby="heading_<%= rule.id %>" data-bs-parent="#accordion">
			<div class="card-body">
				<span class="text-muted"><%= rule.description %></span>
			</div>
			<ul class="list-group list-group-flush">

				<% rule.rule_options.each do |rule_option| %>
					<li class="list-group-item">
						<span>
							<strong><%= rule_option.name %></strong>
							<p class="text-muted"><%= rule_option.description %></p>
						</span>

						<div id='form_<%= rule_option.id %>'>
							<div id='policy_rule_options'>
								<%= f.fields_for :policy_rule_options do |policy_rule_option| %>
									<% if policy_rule_option.object.rule_option == rule_option %>
										<%= render 'admin/policies/fields/policy_rule_option_fields', :f => policy_rule_option, rule_option: rule_option, cached: true%>
									<% end %>
								<% end %>
							</div>
							<div class='links_<%= rule_option.id %>'>
								<%= link_to_add_association "+", f, :policy_rule_options, render_options:  {locals: { rule_option: rule_option }}, partial:  'admin/policies/fields/policy_rule_option_fields', class: 'btn btn-success btn-sm' %>
							</div>
						</div>
						<script type="text/javascript">
							$(function() {
								function check_to_hide_or_show_add_link() {
									if (($('#form_<%= rule_option.id %> .nested-fields').length == 1)) {
										$('#form_<%= rule_option.id %> .links_<%= rule_option.id %>').hide();
									} else {
										$('#form_<%= rule_option.id %> .links_<%= rule_option.id %> a.add_fields').click()


									}
								}

								$('#form_<%= rule_option.id %>').on('cocoon:after-insert', function() {
									$('#form_<%= rule_option.id %> .links_<%= rule_option.id %>').hide();

								});

								$('#form_<%= rule_option.id %>').on('cocoon:after-remove', function() {
									$('#form_<%= rule_option.id %> .links_<%= rule_option.id %>').show();

									$('#form_<%= rule_option.id %> .links_<%= rule_option.id %> a.add_fields').click()

								});

								check_to_hide_or_show_add_link();
							});
						</script>
					</li>
				<% end %>
			</ul>
		</div>
	</div>
</div>
