<div class="container py-4">
  <div class="row">
    <div class="col col-md-8 offset-md-2">
      <p>
        <strong>Name:</strong>
        <%= @platform.name %>
      </p>

      <p>
        <strong>Slug:</strong>
        <%= @platform.slug %>
      </p>

      <p>
        <strong>Language:</strong>
        <%= @platform.language %>
      </p>

      <p>
        <strong>Framework:</strong>
        <%= @platform.framework %>
      </p>

      <p>
        <strong>Image:</strong>
        <%= raw @platform.image %>
      </p>

      <%= link_to 'Edit', edit_platform_path(@platform) %> |
      <%= link_to 'Back', platforms_path %>

    </div>
  </div>
</div>
