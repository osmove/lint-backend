<div class="container py-2">
  <div class="row justify-content-between">

    <h2>Platforms <span class="badge badge-secondary"><%= @platforms.length %></span></h2>

    <%= paginate @platforms %>

  </div>

  <div class="row my-2">
    <a href="<%= new_admin_platform_path %>" class="btn btn-success">
      + New Platform
    </a>
  </div>

</div>

<div class="table-responsive">
  <table class="table">
    <thead>
      <tr>
        <th width="30">Image</th>
        <th>Name</th>
        <th>Slug</th>
        <th>Language</th>
        <th>Framework</th>
        <th>Popular</th>
        <th colspan="3"></th>
      </tr>
    </thead>

    <tbody>
      <% @platforms.each do |platform| %>
        <tr>
          <td><img src="<%= raw platform.image_url %>" alt="<%= platform.name %>"></td>
          <!-- <td><img src="" alt=""><%= raw platform.image %></td> -->
          <td><%= platform.name %></td>
          <td><%= platform.slug %></td>
          <td><%= platform.language %></td>
          <td><%= platform.framework %></td>
          <td><%= platform.is_popular %></td>
          <td><%= link_to 'Show', admin_platform_url(platform), class: "btn btn-sm btn-primary" %>
          <td><%= link_to 'Edit',  edit_admin_platform_path(platform), class: "btn btn-sm btn-info" %>
          <td><%= link_to 'Destroy', admin_platform_url(platform), method: :delete, data: { confirm: 'Are you sure?' }, class: "btn btn-sm btn-danger" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
