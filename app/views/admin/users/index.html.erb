<div class="container-fluid py-2">

  <div class="row justify-content-between">
    <h1>Users</h1>
    <%= paginate @users %>
  </div>
  <div class="row">
    <%= link_to "+ New User", new_admin_user_path, class: "btn btn-primary my-3" %>
  </div>

</div>

<table class="table table-hover">
  <thead>
    <tr>
      <th class="text-muted">ID</th>
      <th>Name</th>
      <th>Username</th>
      <th>Email</th>
      <th>Role</th>
      <th>Repositories</th>
      <th>Country</th>
      <th>Created</th>

      <th colspan="2"></th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td class="text-muted"><%= user.id %></td>
        <td>
          <% if user.first_name.present? %><%= user.first_name %><% end %>
          <% if user.last_name.present? %><%= user.last_name %><% end %>
        </td>

        <td><%= user.email %></td>
        <td><%= user.username %></td>

        <td>
          <%= user.role %>
        </td>
        <td><%= user.repositories.count %><br/></td>

        <td><%= user.country %></td>
        <td><%= user.created_at.strftime('%A %d %B %Y') %></td>
        <td>
          <%= link_to 'Show', admin_user_path(user), class: "btn btn-sm btn-primary" %>
          <%= link_to 'Edit', edit_admin_user_path(user), class: "btn btn-sm btn-info" %>
          <%= link_to 'Destroy', admin_user_url(user), method: :delete, data: { confirm: 'Are you sure?' }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
