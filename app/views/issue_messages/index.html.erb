<p id="notice"><%= notice %></p>

<h1>Issue Messages</h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Slug</th>
      <th>Body</th>
      <th>Username</th>
      <th>Issue</th>
      <th>Repository</th>
      <th>User</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @issue_messages.each do |issue_message| %>
      <tr>
        <td><%= issue_message.title %></td>
        <td><%= issue_message.slug %></td>
        <td><%= issue_message.body %></td>
        <td><%= issue_message.username %></td>
        <td><%= issue_message.issue %></td>
        <td><%= issue_message.repository %></td>
        <td><%= issue_message.user %></td>
        <td><%= link_to 'Show', issue_message %></td>
        <td><%= link_to 'Edit', edit_issue_message_path(issue_message) %></td>
        <td><%= link_to 'Destroy', issue_message, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Issue Message', new_issue_message_path %>
