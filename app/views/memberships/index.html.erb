<p id="notice"><%= notice %></p>

<h1>Memberships</h1>

<table class="table">
  <thead>
    <tr>
      <th>Username</th>
      <th>Origin</th>
      <th>Origin url</th>
      <th>Avatar url</th>
      <th>Role</th>
      <th>Organization</th>
      <th>Team</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @memberships.each do |membership| %>
      <tr>
        <td><%= link_to membership.user.username, user_path(membership.user) %></td>
        <td><%= membership.origin %></td>
        <td><%= membership.origin_url %></td>
        <td><img src="<%= membership.avatar_url %>" style="width: 50px; height: 50px; float: left; border-radius: 25px;" alt=""> </td>
        <td><%= membership.role %></td>
        <td><%= link_to membership.organization.username, user_path(membership.organization) %></td>
        <td>
          <% if membership.team.present? %>
            <% if membership.team.team_id.present? %>
              <%= link_to membership.team.team_id, team_path(membership.team.team_id) %>
            <% end %>
            <%= link_to "/#{membership.team.name}", team_path(membership.team) %>
          <% end %>
        </td>
        <!-- <td><%#= link_to 'Show', user_team_membership_path(membership.user, membership.team ,membership) %></td>
        <td><%#= link_to 'Edit', edit_user_team_membership_path(membership.user, membership.team ,membership) %></td>
        <td><%#= link_to 'Destroy', user_team_membership_path(membership.user, membership.team ,membership), method: :delete, data: { confirm: 'Are you sure?' } %></td> -->
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Membership', new_user_team_membership_path %>
