<% content_for :title do %>Apps — Lint<% end %>
<% content_for :meta_description do %>Lint is an ecosystem of CLI, desktop, mobile and cloud apps. One engine, every surface.<% end %>

<section class="relative isolate py-16 md:py-20 overflow-hidden">
  <div aria-hidden="true"
       class="pointer-events-none absolute -top-32 -right-32 -z-10 h-[560px] w-[560px] rounded-full"
       style="background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, rgba(34,211,238,0) 70%);"></div>

  <div class="max-w-6xl mx-auto px-4">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/30 text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">
      Apps
    </div>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-[1.05]">One engine. Every surface.</h1>
    <p class="mt-5 text-base md:text-lg text-slate-300 max-w-3xl leading-relaxed">
      Lint runs the same analysis whether you're at the terminal, in your editor, in CI, on your phone, or in the cloud dashboard. Pick the surface that fits the moment.
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <% [
        {
          eyebrow: "CLI", title: "Lint CLI", body: "One npm install away. Pre-commit hook, CI step, on-demand check.",
          cta: "npm install -g lint", href: "/downloads",
          mono: true
        },
        {
          eyebrow: "Cloud", title: "Lint Cloud", body: "Shared policy across your team. Audit log. CI gating webhooks. SSO.",
          cta: "Start trial →", href: "/pricing"
        },
        {
          eyebrow: "Desktop", title: "Lint Desktop", body: "macOS, Windows, Linux native app. Browse violations and configure rules visually.",
          cta: "Download →", href: "/downloads"
        },
        {
          eyebrow: "Mobile", title: "Lint Connect", body: "Approve overrides, browse violations, get notified — wherever you are.",
          cta: "Get the app →", href: "/downloads"
        },
      ].each do |a| %>
        <a href="<%= a[:href] %>" class="group block p-7 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-brand-500/40 hover:bg-white/[0.05] transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-12 h-12 rounded-xl bg-[#0b1120] ring-1 ring-white/10 flex items-center justify-center">
              <svg viewBox="0 0 100 100" class="w-7 h-7" aria-hidden="true">
                <g fill="none" stroke="#22d3ee" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="36,32 22,50 36,68"/>
                  <line x1="56" y1="32" x2="44" y2="68"/>
                  <polyline points="64,32 78,50 64,68"/>
                </g>
              </svg>
            </span>
            <span class="text-xs uppercase tracking-wide text-brand-300"><%= a[:eyebrow] %></span>
          </div>
          <h2 class="text-2xl font-bold text-white tracking-tight mb-2"><%= a[:title] %></h2>
          <p class="text-slate-300 leading-relaxed mb-5"><%= a[:body] %></p>
          <% if a[:mono] %>
            <div class="rounded-lg bg-black/40 border border-white/10 p-3 text-sm font-mono text-slate-300">
              <span class="text-brand-400">$</span> <%= a[:cta] %>
            </div>
          <% else %>
            <span class="text-sm text-brand-300 group-hover:text-brand-200 inline-flex items-center gap-1"><%= a[:cta] %></span>
          <% end %>
        </a>
      <% end %>
    </div>

    <div class="mt-12 rounded-2xl bg-gradient-to-br from-brand-500/15 to-brand-500/0 border border-brand-500/30 p-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight mb-3">Same rules everywhere.</h2>
      <p class="text-slate-300 leading-relaxed max-w-2xl mx-auto mb-5">Define your policy once. The CLI, desktop app, CI runner, and mobile app all pull from the same source of truth — Lint Cloud (or your self-hosted server).</p>
      <a href="/features" class="inline-flex items-center gap-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-white px-5 py-3 font-semibold transition-colors">See features →</a>
    </div>
  </div>
</section>
