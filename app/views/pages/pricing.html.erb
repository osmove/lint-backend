<% content_for :title do %>Pricing — Lint<% end %>
<% content_for :meta_description do %>Free local CLI. Free self-hosted server. Pay only when you opt in to cloud collaboration features.<% end %>

<section class="relative isolate py-16 md:py-20 overflow-hidden">
  <div aria-hidden="true"
       class="pointer-events-none absolute -top-32 -right-32 -z-10 h-[560px] w-[560px] rounded-full"
       style="background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, rgba(34,211,238,0) 70%);"></div>

  <div class="max-w-5xl mx-auto px-4 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/30 text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">
      Pricing
    </div>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-[1.05]">Free where it should be.</h1>
    <p class="mt-5 text-base md:text-lg text-slate-300 max-w-3xl mx-auto leading-relaxed">
      Local CLI is free forever. Self-hosting is free. You only pay when you opt in to cloud collaboration — and even then, the small-team tier is generous.
    </p>
  </div>

  <div class="max-w-6xl mx-auto px-4 mt-12 grid grid-cols-1 md:grid-cols-3 gap-5">
    <%# Local %>
    <div class="p-7 rounded-2xl bg-white/[0.03] border border-white/10">
      <div class="text-xs uppercase tracking-wide text-brand-300 mb-2">Local</div>
      <div class="text-4xl font-bold text-white tracking-tight mb-1">Free</div>
      <div class="text-sm text-slate-400 mb-5">forever, MIT license</div>
      <ul class="space-y-2 text-sm text-slate-300 mb-6">
        <li class="flex gap-2"><span class="text-brand-400">✓</span> CLI for macOS, Linux, Windows</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Pre-commit hook</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Multi-language analysis</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Auto-fix suggestions</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Self-host the server</li>
      </ul>
      <a href="/downloads" class="block w-full text-center rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-2.5 font-semibold">Download</a>
    </div>

    <%# Cloud (featured) %>
    <div class="p-7 rounded-2xl bg-gradient-to-br from-brand-500/10 to-brand-500/0 border border-brand-500/40 relative">
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-brand-500 text-slate-950 text-xs font-bold uppercase tracking-wider">Most popular</div>
      <div class="text-xs uppercase tracking-wide text-brand-300 mb-2">Cloud</div>
      <div class="text-4xl font-bold text-white tracking-tight mb-1">$12<span class="text-base text-slate-400 font-normal">/dev/mo</span></div>
      <div class="text-sm text-slate-400 mb-5">billed annually</div>
      <ul class="space-y-2 text-sm text-slate-300 mb-6">
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Everything in Local</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Shared policy across team</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> CI gating webhooks</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Audit log + override approvals</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Email + chat support</li>
      </ul>
      <a href="<%= user_signed_in? ? dashboard_path : new_user_session_path %>" class="block w-full text-center rounded-lg bg-brand-500 hover:bg-brand-600 text-white px-4 py-2.5 font-semibold">Start 14-day trial</a>
    </div>

    <%# Enterprise %>
    <div class="p-7 rounded-2xl bg-white/[0.03] border border-white/10">
      <div class="text-xs uppercase tracking-wide text-brand-300 mb-2">Enterprise</div>
      <div class="text-4xl font-bold text-white tracking-tight mb-1">Custom</div>
      <div class="text-sm text-slate-400 mb-5">talk to us</div>
      <ul class="space-y-2 text-sm text-slate-300 mb-6">
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Everything in Cloud</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> SSO (SAML, OIDC)</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> SLA, dedicated infra option</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> On-prem deploys with support</li>
        <li class="flex gap-2"><span class="text-brand-400">✓</span> Priority roadmap input</li>
      </ul>
      <a href="/contact" class="block w-full text-center rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-2.5 font-semibold">Contact sales</a>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 mt-12 text-center text-sm text-slate-400">
    Pricing in USD. EUR and GBP available at checkout. VAT/sales tax added per jurisdiction.
  </div>
</section>
