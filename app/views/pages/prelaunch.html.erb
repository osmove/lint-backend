                        var $if = $(e.delegateTarget).find('iframe');
                        var src = $if.attr("src");
                        $if.attr("src", '/empty.html');
                        $if.attr("src", src);
                      });
                    </script>
                    <!-- <iframe width="799" height="450" src="https://www.youtube.com/embed/ZB33_S8WtMQ" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe> -->
