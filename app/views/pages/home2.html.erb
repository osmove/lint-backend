    <!-- <h3>With Homebrew</h3> -->
    <p>Download Lint with homebrew.</p>
    <p>First install Homebrew if you don't already have it.</p>
    <!-- <p><kbd>brew install lint</kbd></p> -->
    <p><kbd>/usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"</kbd></p>

    <h4>Installation</h4>
    <p><kbd>brew install lint</kbd></p>
    <h4>Usage</h4>
    <p><kbd>lint</kbd></p>
    <h4>Update</h4>
    <p><kbd>brew upgrade lint</kbd></p>

      <!-- <p> <img src="/images/1.png" alt="Lint Repositories" class="img-fluid"> </p> -->

  <%#
  <p class="text-muted">Use "lint" without an argument to enter interactive mode.</p>
  <p><kbd>lint setup init</kbd></p>
  <p class="text-muted">Use "lint setup init" to get started with Lint.</p>
  <p><kbd>lint .</kbd></p>
  <p class="text-muted">Use "lint ." to lint an entire repository.</p>
  <p><kbd>lint ci</kbd></p>
  <p class="text-muted">Use "lint ci" to run the repo-local quality gate.</p>
  <p><kbd>lint explain run .</kbd></p>
  <p class="text-muted">Use "lint explain run ." to inspect file, linter, and policy decisions.</p>
  <p><kbd>lint hooks install</kbd></p>
  <p class="text-muted">Use "lint hooks install" to install managed git hooks.</p>
  <p><kbd>lint auth login</kbd></p>
  <p class="text-muted">Use "lint auth login" to connect the CLI to your account.</p>
  <p><kbd>lint --help</kbd></p>
  <p class="text-muted">Use "lint --help" to list all commands.</p>
