<% content_for :title do %>Lint — Quality gate for AI-generated code<% end %>
<% content_for :meta_description do %>Lint is the quality gate for AI-generated code. Catch bad patterns, enforce conventions, and block bad code before it ships — locally, in CI, or in the cloud.<% end %>

<%# ── Hero %>
<section class="relative isolate -mx-4 sm:-mx-6 px-4 sm:px-6 mb-16 pt-24 md:pt-32 pb-16 md:pb-24 overflow-hidden">
  <div aria-hidden="true"
       class="pointer-events-none absolute -top-40 -right-40 -z-10 h-[760px] w-[760px] rounded-full"
       style="background: radial-gradient(circle, rgba(34,211,238,0.24) 0%, rgba(34,211,238,0) 70%);"></div>
  <div aria-hidden="true"
       class="pointer-events-none absolute -bottom-40 -left-40 -z-10 h-[560px] w-[560px] rounded-full"
       style="background: radial-gradient(circle, rgba(34,211,238,0.10) 0%, rgba(34,211,238,0) 70%);"></div>

  <div class="max-w-5xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/30 text-brand-300 text-xs font-semibold uppercase tracking-wider mb-6">
      Quality Gate · Open Source · Local & Cloud
    </div>
    <h1 class="text-4xl md:text-7xl lg:text-[5rem] font-bold tracking-tight leading-[1.02]">
      <span class="text-white">Block bad code</span>
      <br>
      <span class="bg-gradient-to-r from-brand-200 via-brand-300 to-brand-400 bg-clip-text text-transparent">before it ships.</span>
    </h1>
    <p class="mt-6 md:mt-8 text-base md:text-lg lg:text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
      Lint is the quality gate for AI-generated code. Detect bad patterns, enforce conventions, and stop regressions — locally on your machine, in CI, or in the cloud. One tool, every language.
    </p>
    <div class="mt-8 md:mt-10 flex items-center justify-center gap-3 flex-wrap">
      <a href="/downloads" class="inline-flex items-center gap-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-white px-6 py-3 font-semibold shadow-lg shadow-brand-500/20 hover:shadow-brand-500/40 hover:-translate-y-0.5 transition-all">
        Download for free
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
      <a href="#how-it-works" class="inline-flex items-center rounded-lg bg-white/5 hover:bg-white/10 text-slate-200 border border-white/10 px-6 py-3 font-semibold transition-colors">How it works</a>
    </div>

    <%# Quick install %>
    <div class="mt-10 max-w-xl mx-auto">
      <div class="rounded-xl bg-black/40 border border-white/10 p-4 text-left text-sm font-mono text-slate-300">
        <span class="text-brand-400">$</span> npm install -g lint
      </div>
    </div>
  </div>
</section>

<%# ── How it works %>
<section id="how-it-works" class="py-12 md:py-20 reveal" data-reveal>
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/30 text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">
        How it works
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">Three steps. Zero broken builds.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% [
        { num: "01", title: "Install", body: "One command. Works on macOS, Linux, Windows. Install globally or per-project." },
        { num: "02", title: "Configure", body: "Point Lint at your repo. It infers your stack and proposes a starting policy you can tighten." },
        { num: "03", title: "Gate", body: "Run locally before commit, in CI before merge, or in the cloud for shared rules across your team." },
      ].each do |s| %>
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/10">
          <div class="text-xs font-mono text-brand-400 mb-3"><%= s[:num] %></div>
          <h3 class="text-lg font-semibold text-white mb-2"><%= s[:title] %></h3>
          <p class="text-sm text-slate-300 leading-relaxed"><%= s[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Why Lint %>
<section class="py-12 md:py-20 reveal" data-reveal>
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/30 text-brand-300 text-xs font-semibold uppercase tracking-wider mb-3">
          Why Lint
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight mb-3">Built for the AI-generated code era.</h2>
        <p class="text-slate-300 text-base leading-relaxed">AI assistants ship more code than ever. Lint keeps the bar high — without slowing you down.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% [
        { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", title: "Catch what AI misses", body: "Static analysis tuned for patterns AI assistants frequently introduce — silent error swallowing, dead branches, copy-paste leaks." },
        { icon: "M13 10V3L4 14h7v7l9-11h-7z", title: "Fast feedback loop", body: "Lint runs in milliseconds locally. No waiting for the CI pipeline to surface an issue you should have caught at commit time." },
        { icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z", title: "Local-first by default", body: "Your code never leaves your machine unless you opt in to the cloud. Self-host, run offline, audit the source." },
        { icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z", title: "Block at the gate", body: "Pre-commit hook, CI step, cloud webhook — whichever fits your workflow. Same rules, same result." },
        { icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10", title: "Team-wide rules, zero drift", body: "Push your policy to Lint Cloud and every developer + CI run pulls the same authoritative ruleset." },
        { icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", title: "Made by Osmove", body: "Built and operated by Osmove SASU, the Paris studio behind Twoody and Backlog. One brand, one quality bar." },
      ].each do |f| %>
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-brand-500/30 hover:bg-white/[0.05] transition-colors">
          <div class="w-9 h-9 rounded-lg bg-brand-500/10 border border-brand-500/30 flex items-center justify-center text-brand-300 mb-3">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= f[:icon] %>"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white mb-1.5"><%= f[:title] %></h3>
          <p class="text-sm text-slate-300 leading-relaxed"><%= f[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── CTA %>
<section class="py-16 md:py-20 reveal" data-reveal>
  <div class="max-w-5xl mx-auto px-4">
    <div class="rounded-2xl bg-gradient-to-br from-brand-500/30 to-brand-700/30 border border-brand-500/30 p-8 md:p-12 text-center">
      <h3 class="text-white text-2xl md:text-3xl font-bold tracking-tight">Ship code you trust.</h3>
      <p class="mt-3 text-slate-200 leading-relaxed">Free to install. Free to self-host. Pay only for the cloud features you need.</p>
      <div class="mt-6 flex items-center justify-center gap-3 flex-wrap">
        <a href="/downloads" class="inline-flex items-center gap-2 rounded-lg bg-white text-slate-950 hover:bg-white/90 px-5 py-3 font-semibold transition-colors">Get Lint</a>
        <a href="/pricing" class="inline-flex items-center rounded-lg bg-white/10 hover:bg-white/15 text-white border border-white/10 px-5 py-3 font-semibold transition-colors">See pricing</a>
      </div>
    </div>
  </div>
</section>
