<% content_for :title do %>Features — Lint<% end %>
<% content_for :meta_description do %>Static analysis, policy as code, fast feedback, cloud collaboration. Everything Lint does to keep AI-generated code production-ready.<% end %>

<section class="relative isolate py-16 md:py-20 overflow-hidden">
  <div aria-hidden="true"
       class="pointer-events-none absolute -top-32 -right-32 -z-10 h-[560px] w-[560px] rounded-full"
       style="background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, rgba(34,211,238,0) 70%);"></div>

  <div class="max-w-6xl mx-auto px-4">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/30 text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">
      Features
    </div>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-[1.05]">Everything you need to gate code.</h1>
    <p class="mt-5 text-base md:text-lg text-slate-300 max-w-3xl leading-relaxed">
      Lint is purpose-built for the era where most code is written with AI help. The features below are what we found we needed at Osmove to keep the bar high without slowing the team down.
    </p>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      <% [
        { title: "Static analysis", body: "Type-flow, dead-code, unused-import, suspicious patterns. Detection tuned for what AI assistants frequently produce." },
        { title: "Policy as code", body: "Your rules live next to your code, in YAML. Version-controlled, review-able, diff-able." },
        { title: "Pre-commit hook", body: "Catch issues at the keystroke level. No more 'fixed lint' commits five minutes after the original." },
        { title: "CI integration", body: "GitHub Actions, GitLab CI, Bitbucket, Jenkins. One YAML snippet and you're gated at the PR level." },
        { title: "Cloud rules sync", body: "Push your policy to Lint Cloud and every dev machine + CI pulls the canonical version. No drift." },
        { title: "Multi-language", body: "Ruby, Python, JavaScript, TypeScript, Go, Rust, Java. One config style across stacks." },
        { title: "Fix suggestions", body: "Most checks come with auto-fix. Apply locally, review the diff, ship. Or let CI auto-apply on merge." },
        { title: "Audit log", body: "Cloud-only: every policy change, every block decision, every override is recorded with author + reason." },
      ].each do |f| %>
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-brand-500/30 hover:bg-white/[0.05] transition-colors">
          <h3 class="text-lg font-semibold text-white mb-2"><%= f[:title] %></h3>
          <p class="text-sm text-slate-300 leading-relaxed"><%= f[:body] %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-12">
      <a href="/pricing" class="inline-flex items-center gap-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-white px-5 py-3 font-semibold transition-colors">See pricing
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</section>
