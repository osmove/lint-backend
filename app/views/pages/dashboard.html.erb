<section class="" style="background-color: #eeeff0;">
  <div class="container py-4 py-lg-5">
    <h2 class="mb-3"><%= current_user.greet %>.</h2>




    <div class="row">



      <div class="col-12 col-md-4">
        <div class="input-group mb-3">
          <div class="input-group-prepend">
            <label class="input-group-text" for="inputGroupSelectRepository">Repository</label>
          </div>
          <select class="custom-select" id="inputGroupSelectRepository">
            <% if !params[:repository].present? %>
              <option selected value="">All</option>
            <% else %>
              <option value="">All</option>
            <% end %>

            <% current_user.repositories_with_access.each do |repository| %>
              <% if params[:repository].present? && params[:repository] == repository.uuid %>
                <option selected value="<%= repository.uuid %>"><%= repository.uuid %></option>
              <% else %>
                <option value="<%= repository.uuid %>"><%= repository.uuid %></option>
              <% end %>
            <% end %>

          </select>
        </div>
      </div>




      <!-- <div class="col-12 col-md-4">
        <div class="input-group mb-3">
          <div class="input-group-prepend">
            <label class="input-group-text" for="inputGroupSelectBranch">Branch</label>
          </div>
          <select class="custom-select" id="inputGroupSelectBranch">
            <% if !params[:branch].present? %>
              <option selected value="">All</option>
            <% else %>
              <option value="">All</option>
            <% end %>

            <% @branches.each do |branch| %>
              <% if params[:branch].present? && params[:branch].gsub(/[^a-zA-Z0-9\-]/,"") == branch.gsub(/[^a-zA-Z0-9\-]/,"") %>
                <option selected value="<%= branch %>"><%= branch %></option>
              <% else %>
                <option value="<%= branch %>"><%= branch %></option>
              <% end %>
            <% end %>

          </select>
        </div>
      </div> -->


      <div class="col-12 col-md-4">
        <div class="input-group mb-3">
          <div class="input-group-prepend">
            <label class="input-group-text" for="inputGroupSelect">User</label>
          </div>

          <select class="custom-select" id="inputGroupSelect">
            <% if !params[:author].present? %>
              <option selected value="">All</option>
            <% else %>
              <option value="">All</option>
            <% end %>

            <% @authors.each do |author| %>
              <% if params[:author].present? && params[:author].to_i == author.id.to_i %>
                <option selected value="<%= author.id %>"><%= author %></option>
              <% else %>
                <option value="<%= author.id %>"><%= author %></option>
              <% end %>
            <% end %>
          </select>
        </div>
      </div>



      <div class="col-12 col-md-4">
        <div class="input-group mb-3">
          <div class="input-group-prepend">
            <label class="input-group-text" for="inputGroupSelectStatus">Status</label>
          </div>
          <select class="custom-select" id="inputGroupSelectStatus">
            <% if !params[:status].present? %>
              <option selected value="">All</option>
            <% else %>
              <option value="">All</option>
            <% end %>

            <% if params[:status].present? && params[:status] == "passed" %>
              <option selected value="passed">Passed</option>
            <% else %>
              <option value="passed">Passed</option>
            <% end %>
            <% if params[:status].present? && params[:status] == "failed" %>
              <option selected value="failed">Failed</option>
            <% else %>
              <option value="failed">Failed</option>
            <% end %>
          </select>
        </div>
      </div>





    </div>



    <div class="row">
      <div class="col-12 col-md-7 col-lg-8">
        <% if @commit_attempts.length > 0 %>




          <div class="card mb-3">
            <div class="card-body pt-1 pb-0">
              <%= column_chart [
                {name: 'Passed', color: 'green', data: current_user.commit_attempts.where(passed: true).group_by_day(:created_at, last: 21).count},
                {name: 'Failed', color: 'red', data: current_user.commit_attempts.where(passed: false).group_by_day(:created_at, last: 21).count},
                {name: 'No policy', color: 'grey', data: current_user.commit_attempts.where(passed: nil).group_by_day(:created_at, last: 21).count}
              ], height: "200px", stacked: true
              %>
            </div>
          </div>





          <div class="card mb-3">
            <div class="card-header">
              Last Commit Attempts
              <!-- <span class="badge badge-secondary"><%#= @last_commit_attempts.count %> -->
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <tbody>
                    <% @commit_attempts.each_with_index do |commit_attempt, index| %>
                      <% if commit_attempt.policy_checks.length > 0 %>
                        <%= render 'commit_attempts/commit_attempt_card_body', commit_attempt: commit_attempt, display_repository: true, i: index, policy_check: commit_attempt.policy_checks.first %>
                      <% else %>
                        <%= render 'commit_attempts/commit_attempt_card_body', commit_attempt: commit_attempt, display_repository: true, i: index, policy_check: nil %>
                      <% end %>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% else %>

          <div class="card mb-3 text-center">
            <div class="card-body pt-5 pb-5">
              <!-- <img src="/images/logo/logo-shield-circle-only-simple.svg" width="110" height="110" class="d-inline-block align-top my-3" alt="Omnilint Logo" style="opacity: 0.5;"> -->
              <h1 class="mb-5 text-muted">Waiting for commits...</h1>
              <h3>Local Install</h3>
              <p>Install with <strong>NPM</strong> (local):</p>
              <div class="mb-5">
                <p><kbd class="p-2">npm install -D omnilint</kbd></p>
              </div>
              <h3>Global Install</h3>
              <p>Install with <strong>NPM</strong> (global):</p>
              <div class="mb-4">
                <p><kbd class="p-2">npm install -g omnilint</kbd></p>
              </div>
              <p>Then inside your repository root:</p>
              <div class="mb-4">
                <p><kbd class="p-2">omnilint install</kbd></p>
              </div>
            </div>
          </div>

        <% end %>
      </div>


      <div class="col-12 col-md-5 col-lg-4">

        <% if current_user.repositories_with_access.length > 0 %>
          <% if current_user.repositories_with_access.length == 1 %>
            <p class="mb-2 text-muted"><small>1 REPOSITORY ACCESS</small></p>
          <% else %>
            <p class="mb-2 text-muted"><small><%= current_user.repositories_with_access.length %> REPOSITORY ACCESSES</small></p>
          <% end %>
          <%= render "users/user_repositories", repositories: current_user.repositories_with_access.order(updated_at: :desc) %>
        <% end %>

        <div class="card my-3 box-shadow">
          <div class="card-header text-muted">
            <div class="row">
              <div class="col">
                <i class="fa fa-building-o mr-1"></i>
                TEAMS
              </div>
              <div class="col text-right">
                <%= link_to "+ New Team", new_user_team_path(current_user) %>
              </div>
            </div>
          </div>
          <div class="card-body bg-light">
            <% if current_user.memberships.joins(:team).count > 0 %>
              <ul class="list-unstyled mb-0">
                <% current_user.memberships.joins(:team).each do |membership| %>
                  <li>
                    <strong><%= link_to "#{membership.team.name}", team_path(membership.team) %></strong>
                    <span class="text-muted ml-2"><%= pluralize(membership.team.memberships.count, 'member') %></span>
                    <span class="text-muted ml-2"><%= "(#{membership.role})" %></span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              No team.
            <% end %>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Facebook Pixel - Complete Registration Event -->
<script>
  fbq('track', 'CompleteRegistration');
</script>



<!-- Filters -->
<script type="text/javascript">

  $('#inputGroupSelectRepository').on('change', function() {
    if (this.value ) {
      var params = '?repository=' + this.value + '&status=' + '<%= params[:status] %>' + '&author=' + '<%= params[:author] %>' + '&branch=' + '<%= params[:branch] %>';
    } else {
      var params = '?repository=' + '' + '&status=' + '<%= params[:status] %>' + '&author=' + '<%= params[:author] %>' + '&branch=' + '<%= params[:branch] %>';
    }
    window.location = params
  });

  $('#inputGroupSelectStatus').on('change', function() {
    if (this.value ) {
      var params = '?status=' + this.value + '&repository=' + '<%= params[:repository] %>' + '&author=' + '<%= params[:author] %>' + '&branch=' + '<%= params[:branch] %>';
    } else {
      var params = '?status=' + '' + '&repository=' + '<%= params[:repository] %>' + '&author=' + '<%= params[:author] %>' + '&branch=' + '<%= params[:branch] %>';
    }
    window.location = params
  });

  $('#inputGroupSelectBranch').on('change', function() {
    if (this.value) {
      var params = '?branch=' + this.value + '&repository=' + '<%= params[:repository] %>' + '&author=' + '<%= params[:author] %>' + '&status=' + '<%= params[:status] %>';
    } else {
      var params = '?branch=' + '' + '&repository=' + '<%= params[:repository] %>' + '&author=' + '<%= params[:author] %>' + '&status=' + '<%= params[:status] %>';
    }
    window.location = params
  });

  $('#inputGroupSelect').on('change', function() {
    if (this.value ) {
      var params = '?author=' + this.value + '&repository=' + '<%= params[:repository] %>' + '&branch=' + '<%= params[:branch] %>' + '&status=' + '<%= params[:status] %>';
    } else {
      var params = '?author=' + '' + '&repository=' + '<%= params[:repository] %>' + '&branch=' + '<%= params[:branch] %>' + '&status=' + '<%= params[:status] %>';
    }
    window.location = params
  });
</script>
