
<nav class="navbar navbar-expand-md navbar-light bg-white">
  <a class="navbar-brand mr-0 mr-md-3" href="<%= root_path %>">
    <!-- <img src="/images/omnilint-logo.png" width="30" height="30" class="d-inline-block align-top" alt="Gatrix Logo"> -->
    <!-- <img src="/images/omnilint-logo-circled@2x.png" width="36" height="36" class="d-inline-block align-top" alt="Gatrix Logo"> -->
    <img src="/images/logo/omnilint-logo.svg" width="36" height="36" class="d-inline-block align-top" alt="Gatrix Logo">

  </a>


  <form class="form-inline form-search input-search mr-0 mr-md-2" id="search" action="/repositories" autocomplete="off">
    <div class="input-group">
      <% if !params["q"].blank? %>
        <input class="form-control typeahead input-search bg-white typeahead-navbar border-right-0" style="border-radius: 5px 0px 0px 5px;" type="search" placeholder="<%= params['q'] %>" aria-label="Search" name="q" value="" autocomplete="off" id="search_input">
      <% else %>
        <input class="form-control typeahead input-search bg-white typeahead-navbar border-right-0" style="border-radius: 5px 0px 0px 5px;" type="search" placeholder="Search..." aria-label="Search" name="q" value="<%= @query %>" autocomplete="off" id="search_input">
      <% end %>
      <div class="input-group-append">
        <button class="btn btn-outline-secondary" type="submit" style="border-color: #cfd4d9;"><i class="fa fa-search"></i></button>
      </div>
    </div>
  </form>

  <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>




  <div class="collapse navbar-collapse" id="navbarSupportedContent">
    <!-- <form class="form-inline mt-2 mt-sm-0">
      <input class="form-control mr-sm-2 mb-2 mb-sm-0" type="search" placeholder="Search" aria-label="Search">
      <button class="btn btn-outline-dark d-none d-sm-block my-2 my-sm-0" type="submit"><i class="fa fa-search"></i></button>
    </form> -->



    <ul class="navbar-nav mr-auto">

      <% if current_page?(root_path) || current_page?(home_path) || current_page?(dashboard_path) %>
        <li class="nav-item active">
          <a class="nav-link" href="<%= home_path %>">Home <span class="sr-only">(current)</span></a>
        </li>
      <% else %>
        <li class="nav-item">
          <a class="nav-link" href="<%= root_path %>">Home</a>
        </li>
      <% end %>

      <% if current_user.present? && current_user.repositories.length > 0 %>

        <li class="nav-item dropdown active">
          <% if @repository.present? && @repository.name.present? %>
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <img src="<%= @repository.platform.image_url %>" width="30" height="30" class="d-inline-block align-top mr-1" alt="Gatrix Logo" style="border-radius: 5px; margin-top: -2px;">
              <span class="">
              <%= @repository.slug %>
              </span>
            </a>
          <% else %>
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              Select repository
            </a>
          <% end %>
          <div class="dropdown-menu" aria-labelledby="navbarDropdown">
            <% current_user.repositories.order(updated_at: :desc).each do |repository| %>
              <a href="<%= user_repository_path(current_user, repository) %>" class="dropdown-item">
                <% if repository.platform.present? %>
                  <img src="<%= repository.platform.image_url %>" alt="<%= repository.platform %>" style="width: 24px; height: 24px; border-radius: 4px; margin-right: 5px;" />
                <% else %>
                  <img src="/images/platformicons/svg/generic.svg" alt="<%= repository.platform %>" style="width: 24px; height: 24px; border-radius: 4px; margin-right: 5px;" />
                <% end %>

                <%= repository.user.slug %> <span class="text-muted">/</span> <strong><%= repository.slug %></strong>
                <% if repository.status == 'Private' %>
                  <i class="fa fa-eye-slash text-muted ml-1"></i>
                <% end %>
                <% if repository.has_encryption %>
                  <i class="fa fa-lock text-muted"></i>
                <% end %>
                <% if repository.requires_two_step_authentication %>
                  <i class="fa fa-shield text-muted"></i>
                <% end %>
                <% if repository.has_deployment %>
                  <i class="fa fa-desktop text-muted"></i>
                  <% end %>
              </a>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>


    <ul class="navbar-nav ml-auto">

      <% if user_signed_in?  %>

        <li class="nav-item">
          <%= link_to("+ Add repository", new_user_repository_path(current_user), class: 'nav-link') %>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <strong><%= current_user.slug %></strong>
          </a>
          <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
            <%= link_to('Profile', current_user, class: 'dropdown-item') %>
            <%= link_to('Billing', plans_path, class: 'dropdown-item') %>
            <%= link_to('Settings', current_user, class: 'dropdown-item') %>
            <div class="dropdown-divider"></div>
            <%= link_to('SSH Keys', current_user, class: 'dropdown-item') %>
            <!-- <div class="d-none d-md-block"> -->
              <div class="dropdown-divider"></div>
              <%= link_to("Sign out", destroy_user_session_path, method: :delete, class: 'dropdown-item', data: { confirm: 'Are you sure you want to sign out of Gatrix?' }) %>
            <!-- </div> -->
          </div>
        </li>
        <!-- <li class="nav-item">
          <%= link_to(current_user.slug, current_user, class: 'nav-link') %>
        </li>
        <li class="nav-item">
          <%= link_to("Sign out", destroy_user_session_path, method: :delete, class: 'nav-link', data: { confirm: 'Are you sure to sign out of Gatrix?' }) %>
        </li> -->
      <% else %>
        <li class="nav-item">
          <%= link_to("Sign in", new_user_session_path, class:'btn btn-outline-dark btn-block-sm-only btn-block-xs-only ml-md-2') %>
        </li>
        <li class="nav-item">
          <%= link_to("Sign up", new_user_registration_path, class:'btn btn-dark btn-block-sm-only btn-block-xs-only ml-md-2') %>
        </li>
      <% end %>
    </ul>

  </div>


</nav>









<script type="text/javascript">
  // Twitter typeahead example.

  var repositories = new Bloodhound({
    datumTokenizer: Bloodhound.tokenizers.obj.whitespace('uuid'),
    queryTokenizer: Bloodhound.tokenizers.whitespace,
    prefetch: '/repositories.json',
    remote: {
      url: '/repositories.json?q=%QUERY',
      wildcard: '%QUERY'
    }
  });
  repositories.initialize(); // initialize the bloodhound suggestion engine

  <% if user_signed_in? %>
  var myRepositories = new Bloodhound({
    datumTokenizer: Bloodhound.tokenizers.obj.whitespace('uuid'),
    queryTokenizer: Bloodhound.tokenizers.whitespace,
    prefetch: '/<%= current_user.slug %>/repositories.json',
    remote: {
      url: '/<%= current_user.slug %>/repositories.json?q=%QUERY',
      wildcard: '%QUERY'
    }
  });
  myRepositories.initialize(); // initialize the bloodhound suggestion engine
  <% end %>


  // instantiate the typeahead UI
  $('.navbar .typeahead').typeahead({
    highlight: true,
    minLength: 0,
  }, {
    <% if user_signed_in? %>
    display: 'uuid',
    // source: myRepositories,
    source: myRepositories.ttAdapter(),
    limit: 5,
    templates: {
      header: '<h6 class="px-3 text-muted bg-light py-2 mb-1" style="border-bottom: 1px solid #ddd; border-top: 1px solid #cfd4d9; font-size: 12px;">MY REPOSITORIES</h6>',
      empty: [
        '<h6 class="px-3 text-muted bg-light py-2 mb-1" style="border-bottom: 1px solid #ddd; border-top: 1px solid #cfd4d9; font-size: 12px;">MY REPOSITORIES</h6>',
        '<div class="text-md-center pt-3 pb-3 pt-md-4 pb-md-4 text-muted">',
          '<p class="px-3 mb-0">No result</p>',
        '</div>'
      ].join('\n'),
    }
  }, {
    <% end %>
    display: 'uuid',
    // source: repositories,
    source: repositories.ttAdapter(),
    limit: 5,
    templates: {
      header: '<h6 class="px-3 text-muted bg-light py-2 mt-1 mb-1" style="border-bottom: 1px solid #ddd; border-top: 1px solid #cfd4d9; font-size: 12px;">PUBLIC REPOSITORIES</h6>',
      empty: [
        '<h6 class="px-3 text-muted bg-light py-2 mt-1 mb-1" style="border-bottom: 1px solid #ddd; border-top: 1px solid #cfd4d9; font-size: 12px;">PUBLIC REPOSITORIES</h6>',
        '<div class="text-md-center pt-3 pb-3 pt-md-4 pb-md-4 text-muted">',
          '<p class="px-3 mb-0">No result</p>',
        '</div>'
      ].join('\n'),
      // suggestion: Handlebars.compile('<div><strong>{{uuid}}</strong> – {{slug}}</div>')
    }
  }).on('typeahead:selected', function(val) {
    // $("form#search").submit()
    window.location = `/${$('#search_input').val()}`
  });
</script>
