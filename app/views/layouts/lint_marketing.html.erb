                  <span class="w-4 h-4 rounded ring-1 ring-white/10 bg-[#0b0b14] flex items-center justify-center">
                    <svg viewBox="0 0 100 100" class="w-3 h-3" aria-hidden="true">
                      <g fill="#a5b4fc">
                        <rect x="32" y="32" width="6" height="36" rx="3"/>
                        <rect x="46" y="22" width="6" height="56" rx="3"/>
