        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="md:col-span-1">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="w-7 h-7 rounded-lg ring-1 ring-white/10 bg-[#0b1120] flex items-center justify-center">
                <svg viewBox="0 0 100 100" class="w-5 h-5" aria-hidden="true">
                  <g fill="none" stroke="#22d3ee" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="36,32 22,50 36,68"/>
                    <line x1="56" y1="32" x2="44" y2="68"/>
                    <polyline points="64,32 78,50 64,68"/>
                  </g>
                </svg>
              </span>
              <span class="font-semibold text-white">Lint</span>
            </div>
            <p class="text-sm leading-relaxed">Quality gate for AI-generated code. Block bad code before it ships.</p>
            <p class="mt-3 text-xs text-slate-500">146 ave Léon Blum, 92160 Antony, France</p>
          </div>

          <div>
            <h4 class="text-white font-semibold mb-3">Product</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/features" class="hover:text-white">Features</a></li>
              <li><a href="/apps" class="hover:text-white">Apps</a></li>
              <li><a href="/pricing" class="hover:text-white">Pricing</a></li>
              <li><a href="/downloads" class="hover:text-white">Download</a></li>
              <li><a href="/security" class="hover:text-white">Security</a></li>
              <li><a href="/about" class="hover:text-white">About</a></li>
              <li><a href="/faq" class="hover:text-white">FAQ</a></li>
              <li><a href="https://www.npmjs.com/package/lint" target="_blank" rel="noopener" class="hover:text-white">npm package ↗</a></li>
            </ul>
          </div>

          <div>
            <h4 class="text-white font-semibold mb-3">Family</h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="https://www.osmove.com" target="_blank" rel="noopener"
                   class="inline-flex items-center gap-1.5 hover:text-white">
                  <span class="w-4 h-4 rounded ring-1 ring-white/10 bg-[#020617] flex items-center justify-center">
                    <svg viewBox="0 0 100 100" class="w-3 h-3" aria-hidden="true">
                      <g fill="none" stroke="#ffffff" stroke-width="6">
                        <rect x="22" y="22" width="56" height="56" rx="8"/>
                        <rect x="32" y="32" width="36" height="36" rx="5"/>
