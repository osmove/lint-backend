<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Lint — Code quality gate" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Lint is the quality gate for AI-generated code. Run lint locally, in CI, or in the cloud — block bad code before it ships.' %>">

    <%= csrf_meta_tags %>
    <meta name="theme-color" content="#0b1120">

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <%# Marketing pages use Tailwind only — Bootstrap is intentionally
        not loaded here so utilities don't conflict. The dashboard
        and app layouts still load Bootstrap on their own. %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <meta property="og:site_name" content="Lint">
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : 'Lint — Code quality gate' %>">
    <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Quality gate for AI-generated code.' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://lint.to<%= request.path %>">
    <meta name="twitter:card" content="summary_large_image">
  </head>

  <body class="bg-slate-950 text-slate-100 antialiased font-sans">
    <%# Sticky translucent navbar — same recipe as Osmove. %>
    <header id="site-navbar"
            class="sticky top-0 z-50 transition-colors duration-200 backdrop-blur-xl bg-slate-950/40 supports-[backdrop-filter]:bg-slate-950/30 border-b border-white/[0.06]">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2.5 group">
            <span class="w-7 h-7 rounded-lg ring-1 ring-white/10 group-hover:ring-brand-400/40 bg-[#0b1120] flex items-center justify-center transition-all">
              <svg viewBox="0 0 100 100" class="w-5 h-5" aria-hidden="true">
                <g fill="none" stroke="#22d3ee" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="36,32 22,50 36,68"/>
                  <line x1="56" y1="32" x2="44" y2="68"/>
                  <polyline points="64,32 78,50 64,68"/>
                </g>
              </svg>
            </span>
            <span class="font-semibold text-white tracking-tight">Lint</span>
          </a>

          <nav class="hidden md:flex items-center gap-1 text-sm">
            <% nav_link  = 'text-slate-300 hover:text-white px-3 py-2 rounded-lg hover:bg-white/5 transition-colors' %>
            <% nav_active = 'text-white px-3 py-2 rounded-lg bg-white/[0.06] ring-1 ring-white/10' %>
            <a href="/features"  class="<%= current_page?('/features')  ? nav_active : nav_link %>">Features</a>
            <a href="/apps"      class="<%= current_page?('/apps')      ? nav_active : nav_link %>">Apps</a>
            <a href="/pricing"   class="<%= current_page?('/pricing')   ? nav_active : nav_link %>">Pricing</a>
            <a href="/security"  class="<%= current_page?('/security')  ? nav_active : nav_link %>">Security</a>
            <a href="/about"     class="<%= current_page?('/about')     ? nav_active : nav_link %>">About</a>
            <a href="https://github.com/osmove/lint" target="_blank" rel="noopener" class="<%= nav_link %>">GitHub ↗</a>
            <a href="<%= user_signed_in? ? dashboard_path : new_user_session_path %>"
               class="ml-2 inline-flex items-center gap-1.5 rounded-lg px-4 py-2 transition-all font-medium text-sm bg-brand-500 hover:bg-brand-600 text-white shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30">
              <%= user_signed_in? ? 'Dashboard' : 'Sign in' %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          </nav>

          <button id="nav_toggle" class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg text-slate-300 hover:text-white hover:bg-white/10" aria-label="Toggle menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>

        <div id="mobile_menu" class="md:hidden hidden pb-4 pt-2 border-t border-white/10 mt-2">
          <div class="flex flex-col gap-1">
            <% mobile_link = 'text-slate-300 hover:text-white transition-colors px-3 py-2.5 rounded-lg hover:bg-white/5' %>
            <a href="/features"  class="<%= mobile_link %>">Features</a>
            <a href="/apps"      class="<%= mobile_link %>">Apps</a>
            <a href="/pricing"   class="<%= mobile_link %>">Pricing</a>
            <a href="/security"  class="<%= mobile_link %>">Security</a>
            <a href="/downloads" class="<%= mobile_link %>">Download</a>
            <a href="/about"     class="<%= mobile_link %>">About</a>
            <a href="/faq"       class="<%= mobile_link %>">FAQ</a>
            <a href="https://github.com/osmove/lint" target="_blank" rel="noopener" class="<%= mobile_link %>">GitHub ↗</a>
            <a href="<%= user_signed_in? ? dashboard_path : new_user_session_path %>"
               class="mt-2 inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2.5 transition-colors font-medium bg-brand-500 hover:bg-brand-600 text-white">
              <%= user_signed_in? ? 'Dashboard' : 'Sign in' %> →
            </a>
          </div>
        </div>
      </div>

      <script>
        (function() {
          function init() {
            var btn = document.getElementById('nav_toggle');
            var menu = document.getElementById('mobile_menu');
            if (btn && menu && !btn.dataset.initialized) {
              btn.addEventListener('click', function() { menu.classList.toggle('hidden'); });
              btn.dataset.initialized = 'true';
            }
            var nav = document.getElementById('site-navbar');
            if (nav && !nav.dataset.scrollInit) {
              nav.dataset.scrollInit = 'true';
              var solid = ['bg-slate-950/85', 'shadow-lg', 'shadow-black/20'];
              var translucent = ['bg-slate-950/40'];
              function update() {
                var s = window.scrollY > 24;
                translucent.forEach(c => nav.classList.toggle(c, !s));
                solid.forEach(c => nav.classList.toggle(c, s));
              }
              window.addEventListener('scroll', update, { passive: true });
              update();
            }
          }
          document.addEventListener('DOMContentLoaded', init);
          document.addEventListener('turbo:load', init);
        })();
      </script>
    </header>

    <% if notice.present? %>
      <div class="w-full text-center bg-emerald-600 text-white py-2 text-sm"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="w-full text-center bg-brand-500 text-white py-2 text-sm"><%= alert %></div>
    <% end %>

    <main role="main" class="relative min-h-screen overflow-hidden">
      <%# Global background halo — subtle cyan radial in the upper-right
          corner. Sits behind everything on every marketing page. %>
      <div aria-hidden="true"
           class="pointer-events-none fixed -top-40 -right-40 -z-10 h-[640px] w-[640px] rounded-full"
           style="background: radial-gradient(circle, rgba(34,211,238,0.12) 0%, rgba(34,211,238,0) 70%);"></div>
      <div class="relative container mx-auto px-4">
        <%= yield %>
      </div>
    </main>

