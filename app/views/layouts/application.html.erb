      <script type="text/javascript">
        <% if user_signed_in? %>
          mixpanel.track("<%= current_user.slug %>", "Pageview");
        <% else %>
          mixpanel.track("Pageview");
        <% end %>
      </script>



    <% end %>

  </body>
</html>
