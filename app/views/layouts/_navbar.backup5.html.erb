
<nav class="navbar navbar-expand-md navbar-light bg-light navbar-marketing">
  <a class="navbar-brand mr-0 mr-md-3" href="<%= root_path %>">
    <!-- <img src="/images/omnilint-logo.png" width="30" height="30" class="d-inline-block align-top" alt="Lint.dev Logo"> -->
    <!-- <img src="/images/omnilint-logo-circled@2x.png" width="36" height="36" class="d-inline-block align-top" alt="Lint.dev Logo"> -->
    <img src="/images/logo/omnilint-logo.svg" width="32" height="32" class="d-inline-block align-top" alt="Lint.dev Logo">

  </a>



  <form class="form-inline form-search input-search mr-0 mr-md-2" id="search" action="/repositories" autocomplete="off">
    <div class="input-group" id="scrollable-dropdown-menu">
      <% if !params["q"].blank? %>
        <input class="form-control typeahead input-search bg-white typeahead-navbar border-right-0" style="border-radius: 5px 0px 0px 5px;" type="search" placeholder="<%= params['q'] %>" aria-label="Search" name="q" value="<%= @query %>" autocomplete="off" id="search_input">
      <% else %>
        <input class="form-control typeahead input-search bg-white typeahead-navbar border-right-0" style="border-radius: 5px 0px 0px 5px;" type="search" placeholder="Search..." aria-label="Search" name="q" value="<%= @query %>" autocomplete="off" id="search_input">
      <% end %>
      <div class="input-group-append">
        <!-- <button class="btn btn-outline-secondary" type="submit" style="border-color: #cfd4d9;"><i class="fa fa-search"></i></button> -->
        <button class="btn btn-outline-light" type="submit"  style="border-color: #cfd4d9; color: #aaa;"><i class="fa fa-search"></i></button>
      </div>
    </div>
  </form>

  <!-- <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button> -->


  <button class="navbar-toggler p-1" type="button" data-toggle="collapse" data-target=".collapse" aria-controls="navbarSupportedContent search" aria-expanded="false" aria-label="Toggle navigation" style="border: none; opacity: 0.5;">
    <span class="navbar-toggler-icon"></span>
  </button>


  <div class="collapse navbar-collapse" id="navbarSupportedContent">


    <ul class="navbar-nav mr-auto">


      <% if current_page?(root_path) || current_page?(home_path) %>
        <li class="nav-item active">
          <a class="nav-link" href="<%= root_path %>">Home <span class="sr-only">(current)</span></a>
        </li>
      <% else %>
        <li class="nav-item">
          <a class="nav-link" href="<%= root_path %>">Home</a>
        </li>
      <% end %>

      <% if current_page?(apps_path) %>
        <li class="nav-item active">
          <a class="nav-link" href="<%= apps_path %>">Apps <span class="sr-only">(current)</span></a>
        </li>
      <% else %>
        <li class="nav-item">
          <a class="nav-link" href="<%= apps_path %>">Apps</a>
        </li>
      <% end %>

      <% if current_page?(pricing_path) %>
        <li class="nav-item active">
          <a class="nav-link" href="<%= pricing_path %>">Pricing <span class="sr-only">(current)</span></a>
        </li>
      <% else %>
        <li class="nav-item">
          <a class="nav-link" href="<%= pricing_path %>">Pricing</a>
        </li>
      <% end %>

      <% if current_page?(faq_path) %>
        <li class="nav-item active">
          <a class="nav-link" href="<%= faq_path %>">Help <span class="sr-only">(current)</span></a>
        </li>
      <% else %>
        <li class="nav-item">
          <a class="nav-link" href="<%= faq_path %>">Help</a>
        </li>
      <% end %>

    </ul>


    <ul class="navbar-nav ml-auto mt-2 mt-md-0">
      <% if user_signed_in?  %>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <strong><%= current_user.slug %></strong>
          </a>
          <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
            <%= link_to('Profile', current_user, class: 'dropdown-item') %>
