<script type="text/javascript">

$("body").click(function(evt){
  console.log('1 you clicked on button #' + evt.target.id);
  if(evt.target.id == "btn_magnifier") return;
  if(evt.target.id == "btn_magnifier_magnifier") return;
  if(evt.target.id == "search") return;
  if(evt.target.id == "navbar") return;
  console.log('2 you clicked on button #' + evt.target.id);
  if($(evt.target).closest('#search').length) return;
  console.log('3 you clicked on button #' + evt.target.id);
  // alert('you clicked on button #' + evt.target.id);
  $("#search").collapse('hide');
  $("#btn_magnifier_nav_item").collapse('show');
  // $("#btn_magnifier_nav_item").collapse('show');
});

$("#btn_magnifier, #btn_magnifier_magnifier").click(function(evt){
  $("#btn_magnifier_nav_item").collapse();
  $("#search").collapse('toggle');
  $("#btn_magnifier_nav_item").collapse('hide');
  // $("#search_input").focus();
  setTimeout(function(){
    $("#search_input").focus();
  }, 100);
});


