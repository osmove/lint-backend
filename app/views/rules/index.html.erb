<p id="notice"><%= notice %></p>

<h1>Rules</h1>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Type</th>
      <th>Description</th>
      <th>Status</th>
      <th>Language</th>
      <th>Framework</th>
      <th>Platform</th>
      <th>Parent</th>
      <th>Linter</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @rules.each do |rule| %>
      <tr>
        <td><%= rule.name %></td>
        <td><%= rule.type %></td>
        <td><%= rule.description %></td>
        <td><%= rule.status %></td>
        <td><%= rule.language %></td>
        <td><%= rule.framework %></td>
        <td><%= rule.platform %></td>
        <td><%= rule.parent %></td>
        <td><%= rule.linter.name %></td>
        <td><%= link_to 'Show', rule %></td>
        <td><%= link_to 'Edit', edit_rule_path(rule) %></td>
        <td><%= link_to 'Destroy', rule, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Rule', new_rule_path %>
