<p id="notice"><%= notice %></p>

<h1>Servers</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Ip address</th>
      <th>Os</th>
      <th>Ssh host</th>
      <th>Ssh user</th>
      <th>Ssh password</th>
      <th>Ssh path</th>
      <th>User</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @servers.each do |server| %>
      <tr>
        <td><%= server.name %></td>
        <td><%= server.ip_address %></td>
        <td><%= server.os %></td>
        <td><%= server.ssh_host %></td>
        <td><%= server.ssh_user %></td>
        <td><%= server.ssh_password %></td>
        <td><%= server.ssh_path %></td>
        <td><%= server.user %></td>
        <td><%= link_to 'Show', server %></td>
        <td><%= link_to 'Edit', edit_server_path(server) %></td>
        <td><%= link_to 'Destroy', server, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Server', new_server_path %>
