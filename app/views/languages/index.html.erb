<section class="bg-white">
  <div class="container py-4 py-md-5">

    <div class="row">
      <div class="col-12 col-sm-6">
        <h2>Languages <span class="badge badge-secondary"><%= @languages.length %></span></h2>
      </div>
      <div class="col-12 col-sm-6">
        <p class="text-sm-right">
          <a href="<%= new_language_path %>" class="btn btn-success">
            + New Language
          </a>
        </p>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th width="30">Image</th>
            <th>Name</th>
            <th colspan="3"></th>
          </tr>
        </thead>

        <tbody>
          <% @languages.each do |language| %>
            <tr>
              <td><img src="<%= raw language.image_url %>" alt="<%= language.name %>"></td>
              <!-- <td><%= raw language.image %></div></td> -->
              <td><%= language.name %></td>
              <td><%= link_to 'Show', language %></td>
              <td><%= link_to 'Edit', edit_language_path(language) %></td>
              <td><%= link_to 'Destroy', language, method: :delete, data: { confirm: 'Are you sure?' } %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</section>
