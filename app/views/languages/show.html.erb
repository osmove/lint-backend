<div class="container py-4">
  <div class="row">
    <div class="col col-md-8 offset-md-2">
      <p>
        <strong>Name:</strong>
        <%= @language.name %>
      </p>

      <p>
        <strong>Slug:</strong>
        <%= @language.slug %>
      </p>

      <p>
        <strong>Image:</strong>
        <%= raw @language.image %>
      </p>

      <%= link_to 'Edit', edit_language_path(@language) %> |
      <%= link_to 'Back', languages_path %>
    </div>
  </div>
</div>
