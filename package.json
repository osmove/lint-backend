{
  "name": "lint-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Rails backend for lint.to and the Lint platform APIs.",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "dependencies": {},
  "devDependencies": {
    "lint": "file:../lint-cli"
  },
  "scripts": {
    "setup": "bin/setup",
    "server": "bin/rails server",
    "db:setup": "bin/rails db:create db:migrate db:seed",
    "db:prepare": "bin/rails db:prepare",
    "console": "bin/rails console",
    "test": "bin/rails test",
    "lint": "bundle exec rubocop",
    "security": "bundle exec brakeman",
    "verify": "npm run lint && npm test && npm run security"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/osmove/lint-backend.git"
  },
  "homepage": "https://github.com/osmove/lint-backend#readme",
  "bugs": {
    "url": "https://github.com/osmove/lint-backend/issues"
  },
  "author": "",
  "license": "ISC"
}
