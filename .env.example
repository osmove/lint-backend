# Lint Backend Environment Variables
# Copy this file to .env and fill in the values

# === Rails ===
SECRET_KEY_BASE=
RAILS_MAX_THREADS=5
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# === Database (PostgreSQL) ===
DATABASE_NAME=lint_development
DATABASE_USERNAME=lint
DATABASE_PASSWORD=lint_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432

# === Devise ===
DEVISE_SECRET_KEY=

# === GitHub OAuth ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/users/auth/github

# === Stripe ===
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# === Postmark (Email) ===
POSTMARK_API_TOKEN=

# === Sentry (Error Tracking) ===
SENTRY_DSN=

# === Git Server (SSH) ===
GIT_SERVER_HOST=git.lint.to
GIT_SERVER_USER=root
GIT_SERVER_PASSWORD=

# === AI (Anthropic Claude API) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
SENTRY_TRACES_SAMPLE_RATE=0.1
